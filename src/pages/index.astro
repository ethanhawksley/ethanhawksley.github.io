---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getCollection } from 'astro:content';
import ProjectPreview from '../components/ProjectPreview.astro';
import { personSchema, websiteSchema } from '../lib/schema.ts';
import PostPreview from '../components/PostPreview.astro';
import A from '../components/A.astro';

const allProjects = (await getCollection('projects')).sort(
  (a, b) => a.data.priority - b.data.priority,
);

const allPosts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    websiteSchema,
    {
      '@type': 'ProfilePage',
      '@id': 'https://hawksley.dev/#webpage',
      url: 'https://hawksley.dev/',
      name: 'About Ethan Hawksley',
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      mainEntity: { '@id': 'https://hawksley.dev/#person' },
      inLanguage: 'en-GB',
    },
    personSchema,
  ],
};
---

<Layout
  pageTitle="Ethan Hawksley | CS Student, Systems & Cybersecurity"
  pageDescription="The personal site and technical blog of Ethan Hawksley, a UK-based CS student with a focus on systems programming, low-level computing, and cybersecurity."
  jsonLd={jsonLd}
  ogType="profile"
  isRootPage={true}
>
  <section id="hero" aria-labelledby="hero-heading">
    <h1 id="hero-heading">Ethan Hawksley</h1>
    <p>Hi, I'm Ethan Hawksley, a CS student in the UK.</p>
    <p>I&nbsp;use Linux, write Rust, and enjoy cybersecurity.</p>
  </section>
  <div id="contact-links">
    <SocialLinks />
  </div>
  <section id="projects" aria-labelledby="projects-heading">
    <h2 id="projects-heading">Projects</h2>
    <ul role="list">
      {
        allProjects.map((project) => (
          <ProjectPreview
            name={project.data.name}
            description={project.data.description}
            sourceUrl={project.data.sourceUrl}
            liveUrl={project.data.liveUrl}
            type={project.data.type}
            stack={project.data.stack}
          />
        ))
      }
    </ul>
  </section>
  <section id="blog-callout" aria-labelledby="blog-heading">
    <h2 id="blog-heading">Latest Posts</h2>
    <p>
      Writing about systems programming, web development, and all I learn along
      the way.
    </p>
    <ul id="blog-preview" role="list">
      {
        allPosts
          .slice(0, 2)
          .map((post) => (
            <PostPreview
              url={`/blog/${post.id}/`}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              headingLevel="h3"
            />
          ))
      }
    </ul>
    <A href="/blog/" pressable>View all posts →</A>
  </section>
  <style>
    #hero {
      text-wrap: balance;
      margin-bottom: 1rem;
      max-width: 65ch;
    }

    h1 {
      margin-bottom: 1.5rem;
      text-decoration: var(--color-accent) underline 3px;
      text-underline-offset: 0.25em;
      line-height: var(--leading-tight);
    }

    #contact-links {
      margin-bottom: 2rem;
    }

    h2 {
      margin-bottom: 1rem;
      font-weight: var(--weight-semibold);
      line-height: var(--leading-snug);
    }

    p {
      font-size: var(--font-size-base);
      line-height: var(--leading-normal);
    }

    #projects {
      width: 100%;
    }

    #projects ul {
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    #blog-callout {
      width: 100%;
      margin-top: 2rem;
    }

    #blog-callout > p {
      margin-bottom: 1rem;
    }

    #blog-preview {
      display: flex;
      flex-direction: column;
      width: 100%;
    }
  </style>
</Layout>
