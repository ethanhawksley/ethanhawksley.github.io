---
import fs from 'node:fs';
import path from 'node:path';
import { getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import LatestPosts from '../components/LatestPosts.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ethanHawksleyPhoto from '../assets/ethan-hawksley.png';
import { getSortedPosts, getSortedProjects } from '../utils/content-helpers';
import { personJsonLd, websiteJsonLd } from '../utils/jsonLd';

const optimizedAvif = await getImage({
  src: ethanHawksleyPhoto,
  width: 320,
  height: 320,
  format: 'avif',
});

// Inline low quality avif since home page fits into 1 TCP packet.
const fallbackPath = path.join(
  process.cwd(),
  'src/assets/ethan-hawksley-120.avif',
);
const fallbackBuffer = fs.readFileSync(fallbackPath);
const fallbackBase64 = `data:image/avif;base64,${fallbackBuffer.toString('base64')}`;

const ogImageUrl = new URL('/og/home.png', Astro.site).toString();

const allPosts = await getSortedPosts();
const allProjects = await getSortedProjects();

const projectJsonLds = allProjects.map((project) => {
  const isWeb = project.data.type === 'Web';
  const slug = project.data.name.toLowerCase().replace(/[^a-z0-9]+/g, '-');

  return {
    '@type': isWeb ? 'WebApplication' : 'SoftwareApplication',
    '@id': `https://hawksley.dev/#project-${slug}`,
    url: project.data.url,
    name: project.data.name,
    description: project.data.description,
    applicationCategory: project.data.applicationCategory,
    operatingSystem: isWeb ? 'Any' : 'All',
    creator: { '@id': 'https://hawksley.dev/#person' },
    sameAs: project.data.links?.map((link) => link.url),
    offers: {
      '@type': 'Offer',
      price: 0,
      priceCurrency: 'GBP',
    },
  };
});

const lastModified = allPosts[0].data.pubDate.toISOString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    personJsonLd,
    websiteJsonLd,
    {
      '@type': 'ProfilePage',
      '@id': 'https://hawksley.dev/#webpage',
      url: 'https://hawksley.dev',
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      name: 'About Ethan Hawksley',
      inLanguage: 'en-GB',
      dateCreated: '2024-09-10T00:00:00.000Z',
      dateModified: lastModified,
      mainEntity: { '@id': 'https://hawksley.dev/#person' },
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: 'https://hawksley.dev/ethan-hawksley.png',
        caption: 'Ethan Hawksley',
        width: 1536,
        height: 1536,
      },
    },
    ...projectJsonLds,
  ],
};
---

<Layout
  title="Ethan Hawksley | CS Student, Systems & Cybersecurity"
  description="The personal site and technical blog of Ethan Hawksley, a UK-based CS student with a focus on systems programming, low-level computing, and cybersecurity."
  jsonLd={jsonLd}
  ogType="profile"
  ogImage={ogImageUrl}
  preloadImage={optimizedAvif.src}
  preloadType="image/avif"
>
  <section class="hero">
    <div class="hero-content">
      <h1 id="hero-heading">Ethan Hawksley</h1>
      <p>Hi, I'm Ethan Hawksley, a CS student in the UK.</p>
      <p>I&nbsp;use Linux, write Rust, and enjoy cybersecurity.</p>
    </div>
    <picture>
      <source srcset={optimizedAvif.src} type="image/avif" />
      <img
        src="/ethan-hawksley.png"
        width="1536"
        height="1536"
        alt="Ethan Hawksley"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        class="hero-avatar"
        style={`background-image: url(${fallbackBase64});`}
      />
    </picture>
  </section>
  <div class="contact-links">
    <SocialLinks />
  </div>
  <section class="projects">
    <h2 id="projects-heading">Projects</h2>
    <ul role="list">
      {
        allProjects.map((project) => (
          <ProjectPreview
            name={project.data.name}
            description={project.data.description}
            links={project.data.links}
            url={project.data.url}
            type={project.data.type}
            stack={project.data.stack}
          />
        ))
      }
    </ul>
  </section>
  <section class="blog-callout">
    <h2 id="blog-heading">Latest Posts</h2>
    <p>
      Writing about systems programming, cybersecurity, and all I learn along
      the way.
    </p>
    <LatestPosts />
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    flex-direction: column-reverse;
    gap: 1.5rem;
    align-items: flex-start;
    inline-size: 100%;
    margin-block-end: 1.5rem;
  }

  .hero-content {
    max-inline-size: 65ch;
    text-wrap: balance;
  }

  .hero-avatar {
    inline-size: 120px;
    block-size: 120px;
    color: transparent;
    -webkit-user-select: none;
    user-select: none;
    object-fit: cover;
    background-color: #3e631f;
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    border: 2px solid var(--color-border);
    border-radius: 50%;
    filter: none !important;
  }

  @media (min-width: 38em) {
    .hero {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .hero-avatar {
      inline-size: 160px;
      block-size: 160px;
    }
  }

  .contact-links {
    margin-block-end: 2rem;
  }

  h2 {
    margin-block-end: 1rem;
  }

  p {
    line-height: var(--leading-normal);
  }

  .projects {
    inline-size: 100%;
    margin-block-end: 2rem;
  }

  .projects ul {
    display: flex;
    flex-direction: column;
    inline-size: 100%;
  }
</style>
