---
import Layout from '../layouts/Layout.astro';
import LatestPosts from '../components/LatestPosts.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getSortedPosts, getSortedProjects } from '../utils/content-helpers';
import { personJsonLd, websiteJsonLd } from '../utils/jsonLd';

const ogImageUrl = new URL('/og/home.png', Astro.site).toString();

const allPosts = await getSortedPosts();
const allProjects = await getSortedProjects();

const projectJsonLds = allProjects.map((project) => {
  const isWeb = project.data.type === 'Web';
  const slug = project.data.name.toLowerCase().replace(/[^a-z0-9]+/g, '-');

  return {
    '@type': isWeb ? 'WebApplication' : 'SoftwareApplication',
    '@id': `https://hawksley.dev/#project-${slug}`,
    url: project.data.url,
    name: project.data.name,
    description: project.data.description,
    creator: { '@id': 'https://hawksley.dev/#person' },
    applicationCategory: project.data.applicationCategory,
    operatingSystem: isWeb ? 'Any' : 'All',
    offers: {
      '@type': 'Offer',
      price: 0,
      priceCurrency: 'GBP',
    },
    sameAs: project.data.links?.map((link) => link.url),
  };
});

const lastModified = allPosts[0].data.pubDate.toISOString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    personJsonLd,
    websiteJsonLd,
    {
      '@type': 'ProfilePage',
      '@id': 'https://hawksley.dev/#webpage',
      url: 'https://hawksley.dev/',
      name: 'About Ethan Hawksley',
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      mainEntity: { '@id': 'https://hawksley.dev/#person' },
      dateCreated: '2024-09-10T00:00:00.000Z',
      dateModified: lastModified,
      inLanguage: 'en-GB',
    },
    ...projectJsonLds,
  ],
};
---

<Layout
  title="Ethan Hawksley | CS Student, Systems & Cybersecurity"
  description="The personal site and technical blog of Ethan Hawksley, a UK-based CS student with a focus on systems programming, low-level computing, and cybersecurity."
  jsonLd={jsonLd}
  ogType="profile"
  ogImage={ogImageUrl}
>
  <section class="hero">
    <h1 id="hero-heading">Ethan Hawksley</h1>
    <p>Hi, I'm Ethan Hawksley, a CS student in the UK.</p>
    <p>I&nbsp;use Linux, write Rust, and enjoy cybersecurity.</p>
  </section>
  <div class="contact-links">
    <SocialLinks />
  </div>
  <section class="projects">
    <h2 id="projects-heading">Projects</h2>
    <ul role="list">
      {
        allProjects.map((project) => (
          <ProjectPreview
            name={project.data.name}
            description={project.data.description}
            links={project.data.links}
            url={project.data.url}
            type={project.data.type}
            stack={project.data.stack}
          />
        ))
      }
    </ul>
  </section>
  <section class="blog-callout">
    <h2 id="blog-heading">Latest Posts</h2>
    <p>
      Writing about systems programming, cybersecurity, and all I learn along
      the way.
    </p>
    <LatestPosts />
  </section>
</Layout>

<style>
  .hero {
    max-inline-size: 65ch;
    margin-block-end: 1rem;
    text-wrap: balance;
  }

  .contact-links {
    margin-block-end: 2rem;
  }

  h2 {
    margin-block-end: 1rem;
  }

  p {
    line-height: var(--leading-normal);
  }

  .projects {
    inline-size: 100%;
    margin-block-end: 2rem;
  }

  .projects ul {
    display: flex;
    flex-direction: column;
    inline-size: 100%;
  }
</style>
