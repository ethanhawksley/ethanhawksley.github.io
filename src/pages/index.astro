---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import { personSchema, websiteSchema } from '../utils/schema';
import LatestPosts from '../components/LatestPosts.astro';
import { getSortedPosts, getSortedProjects } from '../utils/content-helpers';

const allPosts = await getSortedPosts();
const allProjects = await getSortedProjects();

const projectSchemas = allProjects.map((project) => {
  const isWeb = project.data.type === 'Web';
  const primaryLanguage = project.data.stack[0];

  return {
    '@type': 'SoftwareSourceCode',
    '@id': `${project.data.sourceUrl}#code`,
    name: project.data.name,
    description: project.data.description,
    codeRepository: project.data.sourceUrl,
    programmingLanguage: {
      '@type': 'ComputerLanguage',
      name: primaryLanguage,
    },
    creator: { '@id': 'https://hawksley.dev/#person' },
    ...(project.data.liveUrl
      ? {
          targetProduct: {
            '@type': isWeb ? 'WebApplication' : 'SoftwareApplication',
            name: project.data.name,
            url: project.data.liveUrl,
            applicationCategory: 'DeveloperApplication',
            operatingSystem: isWeb ? 'Any' : 'All',
            offers: {
              '@type': 'Offer',
              price: '0',
              priceCurrency: 'GBP',
            },
          },
        }
      : {}),
  };
});

const lastModified = new Date(
  Math.max(
    ...allPosts.map((p) => (p.data.modDate || p.data.pubDate).getTime()),
  ),
).toISOString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    websiteSchema,
    {
      '@type': 'ProfilePage',
      '@id': 'https://hawksley.dev/#webpage',
      url: 'https://hawksley.dev/',
      name: 'About Ethan Hawksley',
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      mainEntity: { '@id': 'https://hawksley.dev/#person' },
      inLanguage: 'en-GB',
      dateModified: lastModified,
    },
    personSchema,
    ...projectSchemas,
  ],
};
---

<Layout
  title="Ethan Hawksley | CS Student, Systems & Cybersecurity"
  description="The personal site and technical blog of Ethan Hawksley, a UK-based CS student with a focus on systems programming, low-level computing, and cybersecurity."
  jsonLd={jsonLd}
  ogType="profile"
>
  <section id="hero" aria-labelledby="hero-heading">
    <h1 id="hero-heading">Ethan Hawksley</h1>
    <p>Hi, I'm Ethan Hawksley, a CS student in the UK.</p>
    <p>I&nbsp;use Linux, write Rust, and enjoy cybersecurity.</p>
  </section>
  <div id="contact-links">
    <SocialLinks />
  </div>
  <section id="projects" aria-labelledby="projects-heading">
    <h2 id="projects-heading">Projects</h2>
    <ul role="list">
      {
        allProjects.map((project) => (
          <ProjectPreview
            name={project.data.name}
            description={project.data.description}
            sourceUrl={project.data.sourceUrl}
            liveUrl={project.data.liveUrl}
            type={project.data.type}
            stack={project.data.stack}
          />
        ))
      }
    </ul>
  </section>
  <section id="blog-callout" aria-labelledby="blog-heading">
    <h2 id="blog-heading">Latest Posts</h2>
    <p>
      Writing about systems programming, cybersecurity, and all I learn along
      the way.
    </p>
    <LatestPosts />
  </section>
</Layout>

<style>
  #hero {
    text-wrap: balance;
    margin-block-end: 1rem;
    max-inline-size: 65ch;
  }

  #contact-links {
    margin-block-end: 2rem;
  }

  h2 {
    margin-block-end: 1rem;
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
  }

  p {
    font-size: var(--font-size-base);
    line-height: var(--leading-normal);
  }

  #projects {
    inline-size: 100%;
    margin-block-end: 2rem;
  }

  #projects ul {
    display: flex;
    flex-direction: column;
    inline-size: 100%;
  }
</style>
