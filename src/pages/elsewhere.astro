---
import Layout from '../layouts/Layout.astro';
import A from '../components/A.astro';
import { personJsonLd, websiteRef } from '../utils/jsonLd';
import { profileSections } from '../utils/profiles';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    personJsonLd,
    websiteRef,
    {
      '@type': 'CollectionPage',
      '@id': 'https://hawksley.dev/elsewhere/#webpage',
      url: 'https://hawksley.dev/elsewhere/',
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      name: 'Elsewhere',
      description:
        'Online profiles of Ethan Hawksley, a UK-based CS student. Links to his development, social media, technical writing, and security accounts.',
      inLanguage: 'en-GB',
      about: { '@id': 'https://hawksley.dev/#person' },
      breadcrumb: { '@id': 'https://hawksley.dev/elsewhere/#breadcrumb' },
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: 'https://hawksley.dev/ethan-hawksley.png',
        caption: 'Ethan Hawksley',
      },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://hawksley.dev/elsewhere/#breadcrumb',
      itemListElement: [
        {
          '@type': 'ListItem',
          item: 'https://hawksley.dev',
          position: 1,
          name: 'Home',
        },
        {
          '@type': 'ListItem',
          item: 'https://hawksley.dev/elsewhere/',
          position: 2,
          name: 'Elsewhere',
        },
      ],
    },
  ],
};

const ogImageUrl = new URL('/og/elsewhere.jpg', Astro.site).toString();
---

<Layout
  title="Elsewhere | Ethan Hawksley"
  description="Online profiles of Ethan Hawksley, a UK-based CS student. Links to his development, social media, technical writing, and security accounts."
  jsonLd={jsonLd}
  ogType="website"
  ogImage={ogImageUrl}
>
  <h1>Elsewhere</h1>
  <p>You can find me on various other platforms around the web.</p>
  {
    profileSections.map((section) => {
      const slug = section.title.toLowerCase().replace(/[^a-z0-9]+/g, '-');
      const id = `heading-${slug}`;
      // Internal links are used instead of external for profiles.
      // It reduces the visual clutter of arrows, whilst staying consistent UX.
      return (
        <section>
          <h2 id={id}>{section.title}</h2>
          <ul role="list">
            {section.links.map((link) => (
              <li>
                <span>
                  <A href={link.url} rel="me" external={false} pressable>
                    {link.name}
                  </A>
                </span>
              </li>
            ))}
          </ul>
        </section>
      );
    })
  }
</Layout>

<style>
  p {
    max-inline-size: 65ch;
    margin-block-end: 2rem;
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    text-wrap: balance;
  }

  section {
    inline-size: 100%;
    margin-block-end: 2rem;
  }

  h2 {
    margin-block-end: 1rem;
    font-size: var(--font-size-lg);
  }

  li {
    display: flex;
    align-items: baseline;
    padding-block: 0.75rem;
  }

  li + li {
    border-block-start: 1px solid var(--color-border);
  }

  span {
    font-weight: var(--weight-medium);
  }
</style>
