---
import Layout from '../layouts/Layout.astro';
import A from '../components/A.astro';
import { personRef, websiteRef } from '../utils/schema';
import { profiles } from '../utils/profiles';

const allLinks = profiles.flatMap((section) => section.links);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    websiteRef,
    {
      '@type': 'CollectionPage',
      '@id': 'https://hawksley.dev/elsewhere/#webpage',
      url: 'https://hawksley.dev/elsewhere/',
      name: 'Elsewhere | Ethan Hawksley',
      description:
        'Other platforms, profiles, and directories where you can find Ethan Hawksley on the web.',
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      about: { '@id': 'https://hawksley.dev/#person' },
      inLanguage: 'en-GB',
      breadcrumb: { '@id': 'https://hawksley.dev/elsewhere/#breadcrumb' },
    },
    personRef,
    {
      '@type': 'ItemList',
      '@id': 'https://hawksley.dev/elsewhere/#profiles',
      name: 'Ethan Hawksley Online Profiles',
      itemListElement: allLinks.map((link, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: link.name,
        url: link.url,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://hawksley.dev/elsewhere/#breadcrumb',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://hawksley.dev/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Elsewhere',
          item: 'https://hawksley.dev/elsewhere/',
        },
      ],
    },
  ],
};
---

<Layout
  title="Elsewhere | Ethan Hawksley"
  description="Platforms, profiles, and communities where you can find Ethan Hawksley's work, writing, and security research across the web."
  jsonLd={jsonLd}
  ogType="website"
>
  <h1>Elsewhere</h1>
  <p class="intro">
    You can find me on various other platforms around the web.
  </p>
  {
    profiles.map((section) => {
      const slug = section.title.toLowerCase().replace(/[^a-z0-9]+/g, '-');
      const id = `heading-${slug}`;
      // Internal links are used instead of external for profiles.
      // It reduces the visual clutter of arrows, whilst staying consistent UX.
      return (
        <section class="group" aria-labelledby={id}>
          <h2 id={id}>{section.title}</h2>
          <ul class="elsewhere-list" role="list">
            {section.links.map((link) => (
              <li>
                <span class="platform">
                  <A href={link.url} rel="me" external={false} pressable>
                    {link.name}
                  </A>
                </span>
              </li>
            ))}
          </ul>
        </section>
      );
    })
  }
</Layout>

<style>
  .intro {
    max-inline-size: 65ch;
    margin-block-end: 2rem;
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    text-wrap: balance;
  }

  .group {
    inline-size: 100%;
    margin-block-end: 2rem;
  }

  .group h2 {
    margin-block-end: 1rem;
    font-size: var(--font-size-lg);
  }

  .elsewhere-list li {
    display: flex;
    align-items: baseline;
    padding-block: 0.75rem;
  }

  .elsewhere-list li + li {
    border-block-start: 1px solid var(--color-border);
  }

  .platform {
    font-weight: var(--weight-medium);
  }
</style>
