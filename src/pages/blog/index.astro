---
import Layout from '../../layouts/Layout.astro';
import PostPreview from '../../components/PostPreview.astro';
import { getSortedPosts } from '../../utils/content-helpers';
import { personJsonLd, websiteRef } from '../../utils/jsonLd';

const allPosts = await getSortedPosts();
const lastModified = allPosts[0].data.pubDate.toISOString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    personJsonLd,
    websiteRef,
    {
      '@type': 'CollectionPage',
      '@id': 'https://hawksley.dev/blog/#webpage',
      url: 'https://hawksley.dev/blog/',
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      name: "Ethan Hawksley's Blog",
      description:
        'Technical blog of Ethan Hawksley, a UK-based CS student. Articles on systems programming, low-level computing, cybersecurity, and computer science.',
      inLanguage: 'en-GB',
      dateModified: lastModified,
      mainEntity: { '@id': 'https://hawksley.dev/blog/#blog' },
      breadcrumb: { '@id': 'https://hawksley.dev/blog/#breadcrumb' },
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: 'https://hawksley.dev/ethan-hawksley-monogram-square.png',
        caption: 'Ethan Hawksley Monogram',
      },
    },
    {
      '@type': 'Blog',
      '@id': 'https://hawksley.dev/blog/#blog',
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      mainEntityOfPage: { '@id': 'https://hawksley.dev/blog/#webpage' },
      name: "Ethan Hawksley's Blog",
      description:
        'Technical blog of Ethan Hawksley, a UK-based CS student. Articles on systems programming, low-level computing, cybersecurity, and computer science.',
      inLanguage: 'en-GB',
      dateModified: lastModified,
      publisher: { '@id': 'https://hawksley.dev/#person' },
      license: 'https://creativecommons.org/licenses/by/4.0/',
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://hawksley.dev/blog/#breadcrumb',
      itemListElement: [
        {
          '@type': 'ListItem',
          item: 'https://hawksley.dev/',
          position: 1,
          name: 'Home',
        },
        {
          '@type': 'ListItem',
          item: 'https://hawksley.dev/blog/',
          position: 2,
          name: 'Blog',
        },
      ],
    },
  ],
};

const ogImageUrl = new URL('/og/blog.png', Astro.site).toString();
---

<Layout
  title="Blog | Ethan Hawksley"
  description="Technical blog of Ethan Hawksley, a UK-based CS student. Articles on systems programming, low-level computing, cybersecurity, and computer science."
  jsonLd={jsonLd}
  ogType="website"
  ogImage={ogImageUrl}
>
  <h1>Blog</h1>
  <p>
    Writing about systems programming, cybersecurity, and all I learn along the
    way.
  </p>
  <ul role="list">
    {
      allPosts.map((post) => (
        <PostPreview
          href={`/blog/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          headingLevel="h2"
        />
      ))
    }
  </ul>
</Layout>
<style>
  p {
    max-inline-size: 65ch;
    margin-block-end: 1rem;
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    text-wrap: balance;
  }
</style>
