---
import type { GetStaticPaths } from 'astro';
import { getImage } from 'astro:assets';
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import A from '../../components/A.astro';
import BlogImage from '../../components/BlogImage.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getSortedPosts } from '../../utils/content-helpers';
import { personRef, websiteRef } from '../../utils/schema';

export const getStaticPaths = (async () => {
  const allPosts = await getSortedPosts();

  return allPosts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: allPosts[index + 1] ?? null,
      nextPost: allPosts[index - 1] ?? null,
    },
  }));
}) satisfies GetStaticPaths;

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const words = (post.body ?? '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 238));

let ogImageUrl: string | undefined;
if (post.data.coverImage) {
  const processed = await getImage({
    src: post.data.coverImage,
    width: 1200,
    height: 630,
    format: 'png',
  });
  ogImageUrl = new URL(processed.src, Astro.site).toString();
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    websiteRef,
    {
      '@type': 'WebPage',
      '@id': `https://hawksley.dev/blog/${post.id}/#webpage`,
      url: `https://hawksley.dev/blog/${post.id}/`,
      name: post.data.title,
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      inLanguage: 'en-GB',
      breadcrumb: { '@id': `https://hawksley.dev/blog/${post.id}/#breadcrumb` },
    },
    {
      '@type': 'Blog',
      '@id': 'https://hawksley.dev/blog/#blog',
      url: 'https://hawksley.dev/blog/',
      name: "Ethan Hawksley's Blog",
      publisher: { '@id': 'https://hawksley.dev/#person' },
      inLanguage: 'en-GB',
    },
    {
      '@type': 'BlogPosting',
      '@id': `https://hawksley.dev/blog/${post.id}/#article`,
      mainEntityOfPage: {
        '@id': `https://hawksley.dev/blog/${post.id}/#webpage`,
      },
      url: `https://hawksley.dev/blog/${post.id}/`,
      headline: post.data.title,
      description: post.data.description,
      image: {
        '@type': 'ImageObject',
        '@id': ogImageUrl ?? 'https://hawksley.dev/og-image-1200x630-v2.png',
        url: ogImageUrl ?? 'https://hawksley.dev/og-image-1200x630-v2.png',
        width: 1200,
        height: 630,
      },
      datePublished: post.data.pubDate.toISOString(),
      dateModified:
        post.data.modDate?.toISOString() ?? post.data.pubDate.toISOString(),
      author: { '@id': 'https://hawksley.dev/#person' },
      publisher: { '@id': 'https://hawksley.dev/#person' },
      isPartOf: { '@id': 'https://hawksley.dev/blog/#blog' },
      keywords: post.data.tags,
      articleSection: post.data.tags[0] ?? 'Computer Science',
      inLanguage: 'en-GB',
      license: 'https://creativecommons.org/licenses/by/4.0/',
    },
    personRef,
    {
      '@type': 'BreadcrumbList',
      '@id': `https://hawksley.dev/blog/${post.id}/#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://hawksley.dev/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Blog',
          item: 'https://hawksley.dev/blog/',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: post.data.title,
          item: `https://hawksley.dev/blog/${post.id}/`,
        },
      ],
    },
  ],
};
---

<Layout
  title={`${post.data.title} | Ethan Hawksley`}
  description={post.data.description}
  jsonLd={jsonLd}
  ogType="article"
  ogImage={ogImageUrl}
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: post.data.modDate?.toISOString(),
    tags: post.data.tags,
    readingTime,
  }}
>
  <Fragment slot="svg-symbols">
    <symbol
      id="icon-copy"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="9" y="9" width="13" height="13" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </symbol>
    <symbol
      id="icon-check"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </symbol>
  </Fragment>

  <nav aria-label="Back to blog" class="back-nav">
    <A href="/blog/" pressable>
      <span class="arrow" aria-hidden="true">←</span> Back to blog
    </A>
  </nav>
  <article>
    <header>
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <span>Published <FormattedDate date={post.data.pubDate} /></span>
        {
          post.data.modDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>
                Modified <FormattedDate date={post.data.modDate} />
              </span>
            </>
          )
        }
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
        {
          post.data.tags.length > 0 && (
            <>
              <span aria-hidden="true">·</span>
              <span>{post.data.tags.join(', ')}</span>
            </>
          )
        }
      </div>
    </header>
    <div class="prose">
      <Content components={{ a: A, img: BlogImage }} />
    </div>
  </article>
  <nav class="post-nav" aria-label="Post navigation">
    <div class="nav-links">
      <div class="nav-item nav-prev">
        {
          prevPost && (
            <a href={`/blog/${prevPost.id}/`} class="nav-link">
              <span class="nav-direction">
                <span class="arrow" aria-hidden="true">
                  ←
                </span>
                Previous
              </span>
              <span class="nav-title">{prevPost.data.title}</span>
            </a>
          )
        }
      </div>
      <div class="nav-item nav-next">
        {
          nextPost && (
            <a href={`/blog/${nextPost.id}/`} class="nav-link nav-link-next">
              <span class="nav-direction nav-direction-next">
                Next
                <span class="arrow" aria-hidden="true">
                  →
                </span>
              </span>
              <span class="nav-title">{nextPost.data.title}</span>
            </a>
          )
        }
      </div>
    </div>
    <div class="nav-all">
      <A href="/blog/" pressable>All posts</A>
    </div>
  </nav>
</Layout>
<style is:global>
  .prose {
    inline-size: 100%;
    min-inline-size: 0;
  }

  .prose > :first-child {
    margin-block-start: 0;
  }
  .prose > :last-child {
    margin-block-end: 0;
  }

  .prose :where(h2, h3, h4, h5, h6, p, li, blockquote) {
    max-inline-size: 65ch;
  }

  .prose :where(p, ul, ol) {
    margin-block: 1.5rem;
  }

  .prose li + li {
    margin-block-start: 0.5rem;
  }
  .prose li > :is(ul, ol) {
    margin-block: 0.5rem 0;
  }

  .prose h2 {
    margin-block-start: 2.5rem;
    margin-block-end: 0.75rem;
    font-size: var(--font-size-lg);
  }

  .prose h3 {
    margin-block-start: 2rem;
    margin-block-end: 0.5rem;
    font-size: var(--font-size-md);
  }

  .prose h4 {
    margin-block-start: 1.5rem;
    margin-block-end: 0.5rem;
  }

  .prose :where(h5, h6) {
    margin-block-start: 1.25rem;
    margin-block-end: 0.25rem;
  }

  .prose img {
    border-radius: 1rem;
  }

  .prose blockquote {
    border-inline-start: 4px solid var(--color-accent);
    border-start-end-radius: 0.5rem;
    border-end-end-radius: 0.5rem;
    padding-block: 1rem;
    padding-inline: 1.5rem;
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .prose blockquote > :first-child {
    margin-block-start: 0;
  }
  .prose blockquote > :last-child {
    margin-block-end: 0;
  }

  .prose code {
    font-family: var(--font-mono);
    font-variant-numeric: slashed-zero;
  }

  .astro-code {
    position: relative;
    display: grid;
    inline-size: 100%;
    max-inline-size: 100%;
    padding: 0.5rem;
    overflow-inline: auto;
    overscroll-behavior-inline: contain;
    border: 2px solid var(--color-border);
    border-radius: 0.5rem;
    color: light-dark(var(--shiki-light), var(--shiki-dark));
    background-color: light-dark(var(--shiki-light-bg), var(--shiki-dark-bg));
  }

  .astro-code:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .astro-code code {
    display: block;
    grid-area: 1/1;
    min-inline-size: max-content;
    font-size: var(--font-size-xs);
    font-variant-ligatures: none;
  }

  @media (min-width: 40em) {
    .astro-code code {
      font-size: var(--font-size-sm);
    }
  }

  .astro-code span {
    color: light-dark(var(--shiki-light), var(--shiki-dark));
    font-style: var(--shiki-light-font-style);
    font-weight: var(--shiki-light-font-weight);
    text-decoration: var(--shiki-light-text-decoration);
  }

  [data-theme='dark'] .astro-code span {
    font-style: var(--shiki-dark-font-style);
    font-weight: var(--shiki-dark-font-weight);
    text-decoration: var(--shiki-dark-text-decoration);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .astro-code span {
      font-style: var(--shiki-dark-font-style);
      font-weight: var(--shiki-dark-font-weight);
      text-decoration: var(--shiki-dark-text-decoration);
    }
  }

  .copy-button {
    position: sticky;
    z-index: 10;
    display: none;
    grid-area: 1 / 1;
    align-self: start;
    justify-self: start;
    inset-block-start: 0.5rem;
    inset-inline-start: calc(100% - 2.5rem);
    padding: 0.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-surface);
    color: var(--color-text-muted);
    opacity: 0;
  }

  .js .copy-button {
    display: flex;
  }

  pre.astro-code:hover .copy-button,
  pre.astro-code:focus-within .copy-button {
    opacity: 1;
  }

  .copy-button:hover {
    color: var(--color-accent);
  }

  .copy-button .check-icon {
    display: none;
  }

  .copy-button[data-copied] .copy-icon {
    display: none;
  }

  .copy-button[data-copied] .check-icon {
    display: block;
    color: #22c55e;
  }

  @media (hover: none) {
    .copy-button {
      opacity: 1;
    }
  }
</style>

<style>
  .back-nav {
    inline-size: 100%;
    margin-block-end: 0.5rem;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .back-nav :global(a) {
    text-decoration: none;
  }

  .back-nav .arrow {
    display: inline-block;
    margin-inline-end: 0.15em;
    transition: transform 250ms ease-out;
  }

  .back-nav :global(a:hover) .arrow {
    transform: translateX(-4px);
  }

  article {
    display: flex;
    flex-direction: column;
    inline-size: 100%;
    min-inline-size: 0;
    gap: 1.5rem;
  }

  header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-block-end: 1.5rem;
    border-block-end: 1px solid var(--color-border);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
  }

  .post-nav {
    display: flex;
    flex-direction: column;
    inline-size: 100%;
    gap: 1rem;
    margin-block-start: 2.5rem;
    padding-block-start: 1.5rem;
    border-block-start: 1px solid var(--color-border);
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    color: inherit;
    text-decoration: none;
  }

  .nav-link:active {
    transform: scale(0.96);
  }

  .nav-direction {
    display: flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .nav-direction-next {
    justify-content: flex-end;
  }

  .arrow {
    display: inline-block;
    transition: transform 250ms ease-out;
  }

  .nav-prev .nav-link:hover .arrow {
    transform: translateX(-4px);
  }

  .nav-next .nav-link:hover .arrow {
    transform: translateX(4px);
  }

  .nav-title {
    font-weight: var(--weight-medium);
    color: var(--color-text);
    text-wrap: balance;
    text-decoration: var(--color-accent) underline 2px;
    text-underline-offset: 0.25em;
  }

  .nav-link-next .nav-title {
    text-align: end;
  }

  .nav-link:hover .nav-title {
    color: var(--color-accent);
  }

  .nav-all {
    font-size: var(--font-size-sm);
    text-align: center;
    color: var(--color-text-muted);
  }

  @media (min-width: 40em) {
    .nav-links {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .nav-prev {
      grid-column: 1;
    }
    .nav-next {
      grid-column: 2;
    }
  }
</style>

<script>
  const timeouts = new WeakMap<
    HTMLButtonElement,
    ReturnType<typeof setTimeout>
  >();

  function initCopyButtons() {
    const controller = new AbortController();

    document.addEventListener(
      'click',
      async (event: MouseEvent) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>(
          '.copy-button',
        );
        if (!button) return;
        const code = button
          .closest('pre')
          ?.querySelector('code')
          ?.textContent?.trimEnd();
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code);
        } catch {
          return;
        }
        button.dataset.copied = '';
        button.setAttribute('aria-label', 'Copied!');
        const prev = timeouts.get(button);
        if (prev) clearTimeout(prev);
        timeouts.set(
          button,
          setTimeout(() => {
            delete button.dataset.copied;
            button.setAttribute('aria-label', 'Copy code');
          }, 2000),
        );
      },
      { signal: controller.signal },
    );

    document.addEventListener('astro:before-swap', () => controller.abort(), {
      once: true,
    });
  }

  document.addEventListener('astro:page-load', initCopyButtons);
</script>
