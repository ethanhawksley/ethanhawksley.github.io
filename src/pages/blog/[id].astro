---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import { getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import A from '../../components/A.astro';
import BlogImage from '../../components/BlogImage.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { personRef, websiteRef } from '../../lib/schema.ts';

export const getStaticPaths = (async () => {
  const posts = (await getCollection('posts')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return posts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: posts[index + 1] ?? null,
      nextPost: posts[index - 1] ?? null,
    },
  }));
}) satisfies GetStaticPaths;

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const hasCode = (post.body ?? '').includes('`');

const words = (post.body ?? '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 238));

let ogImageUrl: string | undefined;
if (post.data.coverImage) {
  const processed = await getImage({
    src: post.data.coverImage,
    width: 1200,
    height: 630,
    format: 'png',
  });
  ogImageUrl = new URL(processed.src, Astro.site).toString();
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    websiteRef,
    {
      '@type': 'Blog',
      '@id': 'https://hawksley.dev/blog/#blog',
      url: 'https://hawksley.dev/blog/',
      name: "Ethan Hawksley's Blog",
      publisher: { '@id': 'https://hawksley.dev/#person' },
    },
    {
      '@type': 'BlogPosting',
      '@id': `https://hawksley.dev/blog/${post.id}/#article`,
      mainEntityOfPage: `https://hawksley.dev/blog/${post.id}/`,
      url: `https://hawksley.dev/blog/${post.id}/`,
      headline: post.data.title,
      description: post.data.description,
      image: ogImageUrl ?? 'https://hawksley.dev/og-image-1200x630.png?v=2',
      datePublished: post.data.pubDate.toISOString(),
      dateModified: (post.data.modDate || post.data.pubDate).toISOString(),
      author: { '@id': 'https://hawksley.dev/#person' },
      publisher: { '@id': 'https://hawksley.dev/#person' },
      isPartOf: { '@id': 'https://hawksley.dev/blog/#blog' },
      keywords: post.data.tags,
      wordCount: words,
      inLanguage: 'en-GB',
    },
    personRef,
    {
      '@type': 'BreadcrumbList',
      '@id': `https://hawksley.dev/blog/${post.id}/#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://hawksley.dev/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Blog',
          item: 'https://hawksley.dev/blog/',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: post.data.title,
          item: `https://hawksley.dev/blog/${post.id}/`,
        },
      ],
    },
  ],
};
---

<Layout
  pageTitle={`${post.data.title} | Ethan Hawksley`}
  pageDescription={post.data.description}
  jsonLd={jsonLd}
  ogType="article"
  ogImage={ogImageUrl}
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: post.data.modDate?.toISOString(),
    tags: post.data.tags,
    readingTime,
  }}
  preloadCodeFont={hasCode}
>
  <Fragment slot="svg-symbols">
    <symbol
      id="icon-copy"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="9" y="9" width="13" height="13" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </symbol>
    <symbol
      id="icon-check"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </symbol>
  </Fragment>

  <nav aria-label="Back to blog" class="breadcrumb">
    <A href="/blog/" style="text-decoration: none;">
      <span aria-hidden="true">←</span> Back to blog
    </A>
  </nav>
  <article id="post">
    <header>
      <h1>{post.data.title}</h1>
      <small>
        Published
        <FormattedDate date={post.data.pubDate} />
        {
          post.data.modDate && (
            <>
              · Modified <FormattedDate date={post.data.modDate} />
            </>
          )
        }
        <span>· {readingTime} min read</span>
        {
          post.data.tags.length > 0 && (
            <span> · {post.data.tags.join(', ')}</span>
          )
        }
      </small>
    </header>
    <div class="content">
      <Content components={{ a: A, img: BlogImage }} />
    </div>
  </article>
  <nav class="post-nav" aria-label="Post navigation">
    <div class="nav-prev">
      {
        prevPost && (
          <A href={`/blog/${prevPost.id}/`} style="text-decoration: none;">
            <span class="arrow" aria-hidden="true">
              ←
            </span>
            <span class="nav-title">{prevPost.data.title}</span>
          </A>
        )
      }
    </div>
    <div class="nav-next">
      {
        nextPost && (
          <A href={`/blog/${nextPost.id}/`} style="text-decoration: none;">
            <span class="nav-title">{nextPost.data.title}</span>
            <span class="arrow" aria-hidden="true">
              →
            </span>
          </A>
        )
      }
    </div>
    <div class="nav-all">
      <A href="/blog/">View all posts</A>
    </div>
  </nav>
  <script>
    const timeouts = new WeakMap<
      HTMLButtonElement,
      ReturnType<typeof setTimeout>
    >();

    document.addEventListener('click', async (e: MouseEvent) => {
      const button = (e.target as HTMLElement).closest<HTMLButtonElement>(
        '.copy-button',
      );
      if (!button) return;

      const code = button
        .closest('pre')
        ?.querySelector('code')
        ?.textContent?.trimEnd();
      if (!code) return;

      try {
        await navigator.clipboard.writeText(code);
      } catch {
        return;
      }

      button.dataset.copied = '';
      button.setAttribute('aria-label', 'Copied!');

      const prev = timeouts.get(button);
      if (prev) clearTimeout(prev);

      timeouts.set(
        button,
        setTimeout(() => {
          delete button.dataset.copied;
          button.setAttribute('aria-label', 'Copy code');
        }, 2000),
      );
    });
  </script>
</Layout>
<style is:global>
  .content {
    > :first-child {
      margin-top: 0;
    }

    > :last-child {
      margin-bottom: 0;
    }

    p,
    li {
      max-width: 65ch;
    }

    p {
      margin-block: 1.25rem;
      font-size: var(--font-size-base);
      line-height: var(--line-height-relaxed);
    }

    h2 {
      font-size: var(--font-size-xl);
      margin-top: 1.75rem;
      margin-bottom: 1rem;
      font-weight: var(--font-weight-semibold);
      line-height: var(--line-height-snug);
    }

    h3 {
      font-size: var(--font-size-lg);
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      font-weight: var(--font-weight-semibold);
      line-height: var(--line-height-snug);
    }

    li {
      font-size: var(--font-size-base);
      line-height: var(--line-height-relaxed);
    }

    img {
      border-radius: 1rem;
    }

    blockquote {
      border-left: 4px solid var(--color-accent);
      background: var(--color-surface);
      color: var(--color-text-muted);
      padding: 1rem 1.5rem;
      border-radius: 0 0.5rem 0.5rem 0;
      font-style: italic;
    }

    blockquote > :last-child {
      margin-bottom: 0;
    }
  }

  code {
    font-family:
      'JetBrains Mono', ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
    font-feature-settings:
      'kern' 1,
      'zero' 1;
  }

  .astro-code {
    position: relative;
    border: 2px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.25rem;
    overflow-x: auto;
    max-width: 100%;
  }

  .astro-code code {
    display: block;
    content-visibility: auto;
    contain-intrinsic-size: 0 200px;
    font-size: var(--font-size-xs);
  }

  @media (min-width: 640px) {
    .astro-code code {
      font-size: var(--font-size-sm);
    }
  }

  .astro-code span {
    background-color: transparent !important;
  }

  .dark {
    .astro-code {
      color: var(--shiki-dark) !important;
      background-color: var(--shiki-dark-bg) !important;
    }
    .astro-code span {
      color: var(--shiki-dark) !important;
      font-style: var(--shiki-dark-font-style) !important;
      font-weight: var(--shiki-dark-font-weight) !important;
      text-decoration: var(--shiki-dark-text-decoration) !important;
    }
  }

  html.enable-transitions .astro-code,
  html.enable-transitions .astro-code span {
    transition:
      color 250ms ease-out,
      background-color 250ms ease-out;
  }

  html.enable-transitions .astro-code span {
    transition: color 250ms ease-out;
  }

  .copy-button {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-surface);
    color: var(--color-text-muted);
    cursor: pointer;
    opacity: 0;
    display: flex;
    transition:
      opacity 150ms ease-out,
      color 150ms ease-out;
  }

  pre.astro-code:hover .copy-button,
  .copy-button:focus-visible {
    opacity: 1;
  }

  .copy-button:hover {
    color: var(--color-accent);
  }

  .copy-button .check-icon {
    display: none;
  }

  .copy-button[data-copied] .copy-icon {
    display: none;
  }

  .copy-button[data-copied] .check-icon {
    display: block;
    color: #22c55e;
  }

  @media (hover: none) {
    .copy-button {
      opacity: 1;
    }
  }
</style>

<style>
  .breadcrumb {
    margin-bottom: 0.5rem;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  article {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    h1 {
      font-size: var(--font-size-2xl);
      margin-bottom: 1.5rem;
      text-decoration: var(--color-accent) underline 3px;
      text-underline-offset: 0.5rem;
      font-weight: var(--font-weight-semibold);
      line-height: var(--line-height-tight);
      letter-spacing: var(--letter-spacing-tight);
    }

    small {
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    width: 100%;
  }

  .nav-prev :global(a),
  .nav-next :global(a) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
  }

  .nav-prev :global(a:active),
  .nav-next :global(a:active) {
    transform: scale(0.96);
  }

  .nav-next :global(a) {
    justify-content: flex-end;
    text-align: right;
  }

  .arrow {
    flex-shrink: 0;
  }

  .nav-title {
    text-decoration: var(--color-accent) underline 2px;
    text-underline-offset: 0.25em;
  }

  .nav-all {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (min-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr 1fr;
    }

    .nav-all {
      grid-column: 1 / -1;
    }
  }
</style>
