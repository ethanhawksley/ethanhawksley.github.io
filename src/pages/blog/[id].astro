---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import A from '../../components/A.astro';
import BlogImage from '../../components/BlogImage.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getSortedPosts } from '../../utils/content-helpers';
import { personJsonLd, websiteRef } from '../../utils/jsonLd';

export const getStaticPaths = (async () => {
  const allPosts = await getSortedPosts();

  return allPosts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: allPosts[index + 1] ?? null,
      nextPost: allPosts[index - 1] ?? null,
    },
  }));
}) satisfies GetStaticPaths;

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const words = (post.body ?? '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 238));

const postUrl = `https://hawksley.dev/blog/${post.id}/`;

const ogImageUrl = new URL(`/og/blog/${post.id}.jpg`, Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    personJsonLd,
    websiteRef,
    {
      '@type': 'WebPage',
      '@id': `${postUrl}#webpage`,
      url: postUrl,
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      name: post.data.title,
      inLanguage: 'en-GB',
      breadcrumb: { '@id': `${postUrl}#breadcrumb` },
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: 'https://hawksley.dev/ethan-hawksley-monogram-square.png',
        caption: 'Ethan Hawksley Monogram',
      },
    },
    {
      '@type': 'Blog',
      '@id': 'https://hawksley.dev/blog/#blog',
      url: 'https://hawksley.dev/blog/',
      name: "Ethan Hawksley's Blog",
      inLanguage: 'en-GB',
      publisher: { '@id': 'https://hawksley.dev/#person' },
    },
    {
      '@type': 'BlogPosting',
      '@id': `${postUrl}#blogposting`,
      url: postUrl,
      mainEntityOfPage: { '@id': `${postUrl}#webpage` },
      isPartOf: { '@id': 'https://hawksley.dev/blog/#blog' },
      headline: post.data.title,
      description: post.data.metaDescription,
      articleSection: post.data.tags[0] ?? 'Computer Science',
      ...(post.data.tags.length > 0 && { keywords: post.data.tags.join(', ') }),
      inLanguage: 'en-GB',
      datePublished: post.data.pubDate.toISOString(),
      dateModified:
        post.data.modDate?.toISOString() ?? post.data.pubDate.toISOString(),
      author: { '@id': 'https://hawksley.dev/#person' },
      publisher: { '@id': 'https://hawksley.dev/#person' },
      image: {
        '@type': 'ImageObject',
        '@id': `${postUrl}#blogposting-image`,
        url: ogImageUrl,
        width: 1200,
        height: 630,
      },
      license: 'https://creativecommons.org/licenses/by/4.0/',
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${postUrl}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          item: 'https://hawksley.dev',
          position: 1,
          name: 'Home',
        },
        {
          '@type': 'ListItem',
          item: 'https://hawksley.dev/blog/',
          position: 2,
          name: 'Blog',
        },
        {
          '@type': 'ListItem',
          item: postUrl,
          position: 3,
          name: post.data.title,
        },
      ],
    },
  ],
};
---

<Layout
  title={`${post.data.title} | Ethan Hawksley`}
  description={post.data.metaDescription}
  jsonLd={jsonLd}
  ogType="article"
  ogImage={ogImageUrl}
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: post.data.modDate?.toISOString(),
    tags: post.data.tags,
    readingTime,
  }}
>
  <Fragment slot="svg-symbols">
    <symbol
      id="icon-copy"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="9" y="9" width="13" height="13" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </symbol>
    <symbol
      id="icon-check"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </symbol>
  </Fragment>

  <div class="back-to-blog">
    <A href="/blog/" pressable>
      <span class="arrow" aria-hidden="true">←</span> Back to blog
    </A>
  </div>
  <article>
    <header>
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <span>Published <FormattedDate date={post.data.pubDate} /></span>
        {
          post.data.modDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>
                Modified <FormattedDate date={post.data.modDate} />
              </span>
            </>
          )
        }
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
        {
          post.data.tags.length > 0 && (
            <>
              <span aria-hidden="true">·</span>
              <span class="sr-only">Tags: </span>
              <span>{post.data.tags.join(', ')}</span>
            </>
          )
        }
      </div>
    </header>
    <div class="prose">
      <Content components={{ a: A, img: BlogImage }} />
    </div>
  </article>
  <nav class="post-pager" aria-label="Blog post pagination">
    <div class="pager-links">
      <div class="pager-prev">
        {
          prevPost && (
            <a href={`/blog/${prevPost.id}/`} class="pager-link">
              <span class="pager-link-label">
                <span class="arrow" aria-hidden="true">
                  ←
                </span>
                Previous
              </span>
              <span class="pager-link-title">{prevPost.data.title}</span>
            </a>
          )
        }
      </div>
      <div class="pager-next">
        {
          nextPost && (
            <a
              href={`/blog/${nextPost.id}/`}
              class="pager-link pager-link-next"
            >
              <span class="pager-link-label pager-link-label-next">
                Next
                <span class="arrow" aria-hidden="true">
                  →
                </span>
              </span>
              <span class="pager-link-title">{nextPost.data.title}</span>
            </a>
          )
        }
      </div>
    </div>
    <div class="pager-view-all">
      <A href="/blog/" pressable>All posts</A>
    </div>
  </nav>
</Layout>
<style is:global>
  .prose {
    inline-size: 100%;
    min-inline-size: 0;
  }

  .prose > :first-child {
    margin-block-start: 0;
  }
  .prose > :last-child {
    margin-block-end: 0;
  }

  .prose :where(h2, h3, h4, h5, h6, p, li, blockquote) {
    max-inline-size: 65ch;
  }

  .prose :where(p, ul, ol) {
    margin-block: 1.5rem;
  }

  .prose h2 {
    margin-block-start: 2.5rem;
    margin-block-end: 0.75rem;
    font-size: var(--font-size-lg);
  }

  .prose h3 {
    margin-block-start: 2rem;
    margin-block-end: 0.5rem;
    font-size: var(--font-size-md);
  }

  .prose h4 {
    margin-block-start: 1.5rem;
    margin-block-end: 0.5rem;
  }

  .prose :where(h5, h6) {
    margin-block-start: 1.25rem;
    margin-block-end: 0.25rem;
  }

  .prose li + li {
    margin-block-start: 0.5rem;
  }
  .prose li > :is(ul, ol) {
    margin-block: 0.5rem 0;
  }

  .prose img {
    border-radius: 1rem;
  }

  .prose blockquote {
    padding-block: 1rem;
    padding-inline: 1.5rem;
    font-style: italic;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border-inline-start: 4px solid var(--color-accent);
    border-start-end-radius: 0.5rem;
    border-end-end-radius: 0.5rem;
  }

  .prose blockquote > :first-child {
    margin-block-start: 0;
  }
  .prose blockquote > :last-child {
    margin-block-end: 0;
  }

  .prose code {
    font-family: var(--font-mono);
    font-variant-numeric: slashed-zero;
  }

  .prose :not(pre) > code {
    display: inline-block;
    max-width: 100%;
    padding-block: 0.15em;
    padding-inline: 0.35em;
    font-size: 0.875em;
    vertical-align: bottom;
    overflow-wrap: break-word;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
  }

  .astro-code {
    position: relative;
    display: grid;
    inline-size: 100%;
    max-inline-size: 100%;
    padding: 0.5rem;
    overflow-inline: auto;
    overscroll-behavior-inline: contain;
    color: light-dark(var(--shiki-light), var(--shiki-dark));
    background-color: light-dark(var(--shiki-light-bg), var(--shiki-dark-bg));
    border: 2px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .astro-code:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .astro-code code {
    display: block;
    grid-area: 1/1;
    min-inline-size: max-content;
    font-size: var(--font-size-xs);
    font-variant-ligatures: none;
  }

  .astro-code span {
    font-style: var(--shiki-light-font-style);
    font-weight: var(--shiki-light-font-weight);
    color: light-dark(var(--shiki-light), var(--shiki-dark));
    text-decoration: var(--shiki-light-text-decoration);
    transition: none !important;
  }

  .copy-button {
    position: sticky;
    inset-block-start: 0.5rem;
    inset-inline-start: calc(100% - 2.5rem);
    z-index: 10;
    display: none;
    grid-area: 1 / 1;
    align-self: start;
    justify-self: start;
    padding: 0.25rem;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    opacity: 0;
  }

  .js .copy-button {
    display: flex;
  }

  pre.astro-code:hover .copy-button,
  pre.astro-code:focus-within .copy-button {
    opacity: 1;
  }

  .copy-button:hover {
    color: var(--color-accent);
  }

  .copy-button .check-icon {
    display: none;
  }

  .copy-button[data-copied] .copy-icon {
    display: none;
  }

  .copy-button[data-copied] .check-icon {
    display: block;
    color: #22c55e;
  }

  [data-theme='dark'] .astro-code span {
    font-style: var(--shiki-dark-font-style);
    font-weight: var(--shiki-dark-font-weight);
    text-decoration: var(--shiki-dark-text-decoration);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .astro-code span {
      font-style: var(--shiki-dark-font-style);
      font-weight: var(--shiki-dark-font-weight);
      text-decoration: var(--shiki-dark-text-decoration);
    }
  }

  @media (min-width: 40em) {
    .astro-code code {
      font-size: var(--font-size-sm);
    }
  }

  @media (hover: none) {
    .copy-button {
      opacity: 1;
    }
  }

  @media print {
    .back-to-blog,
    .copy-button,
    .post-pager {
      display: none !important;
    }

    .prose a[href^='http']::after {
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
      word-break: break-all;
      content: ' (' attr(href) ')';
    }

    .prose pre.astro-code {
      overflow-inline: visible !important;
      word-break: break-all !important;
      white-space: pre-wrap !important;
    }

    .prose a span {
      text-decoration-thickness: 0.07em !important;
      text-underline-offset: auto !important;
    }
  }
</style>

<style>
  .arrow {
    display: inline-block;
    transition: transform 250ms ease-out;
  }

  .back-to-blog {
    inline-size: 100%;
    margin-block-end: 0.5rem;
    font-size: var(--font-size-sm);
  }

  .back-to-blog :global(a) {
    color: var(--color-text-muted);
  }

  .back-to-blog :global(a:hover) {
    color: var(--color-accent);
  }

  .back-to-blog .arrow {
    margin-inline-end: 0.15em;
  }

  .back-to-blog :global(a:hover) .arrow {
    transform: translateX(-0.25em);
  }

  article {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    inline-size: 100%;
    min-inline-size: 0;
  }

  header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-block-end: 1.5rem;
    border-block-end: 1px solid var(--color-border);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
  }

  .post-pager {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    inline-size: 100%;
    padding-block-start: 1.5rem;
    margin-block-start: 2.5rem;
    border-block-start: 1px solid var(--color-border);
  }

  .pager-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pager-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    color: inherit;
    text-decoration: none;
  }

  .pager-link:active {
    transform: scale(0.96);
  }

  .pager-link-label {
    display: flex;
    gap: 0.35em;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .pager-link-label-next {
    justify-content: flex-end;
  }

  .pager-link-title {
    font-weight: var(--weight-medium);
    text-wrap: balance;
    text-decoration: var(--color-accent) underline 2px;
    text-underline-offset: 0.25em;
  }

  .pager-link-next .pager-link-title {
    text-align: end;
  }

  .pager-link:hover .pager-link-title {
    color: var(--color-accent);
  }

  .pager-prev .pager-link:hover .arrow {
    transform: translateX(-0.25em);
  }

  .pager-next .pager-link:hover .arrow {
    transform: translateX(0.25em);
  }

  .pager-view-all {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (min-width: 40em) {
    .pager-links {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .pager-prev {
      grid-column: 1;
    }
    .pager-next {
      grid-column: 2;
    }
  }
</style>

<script>
  const timeouts = new WeakMap<
    HTMLButtonElement,
    ReturnType<typeof setTimeout>
  >();

  function initCopyButtons() {
    const controller = new AbortController();

    document.addEventListener(
      'click',
      async (event: MouseEvent) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>(
          '.copy-button',
        );
        if (!button) return;

        const code = button
          .closest('pre')
          ?.querySelector('code')
          ?.textContent?.trimEnd();
        if (!code) return;

        try {
          await navigator.clipboard.writeText(code);
        } catch {
          return;
        }

        button.dataset.copied = '';
        const liveRegion = document.getElementById('a11y-status-announce')!;
        liveRegion.textContent = 'Code copied to clipboard';

        const prev = timeouts.get(button);
        if (prev) clearTimeout(prev);

        timeouts.set(
          button,
          setTimeout(() => {
            delete button.dataset.copied;
            liveRegion.textContent = '';
          }, 2000),
        );
      },
      { signal: controller.signal },
    );

    document.addEventListener('astro:before-swap', () => controller.abort(), {
      once: true,
    });
  }

  document.addEventListener('astro:page-load', initCopyButtons);
</script>
