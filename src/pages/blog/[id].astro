---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import { getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import A from '../../components/A.astro';
import BlogImage from '../../components/BlogImage.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { personRef, websiteRef } from '../../utils/schema';
import { getSortedPosts } from '../../utils/content-helpers';

export const getStaticPaths = (async () => {
  const allPosts = await getSortedPosts();

  return allPosts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: allPosts[index + 1] ?? null,
      nextPost: allPosts[index - 1] ?? null,
    },
  }));
}) satisfies GetStaticPaths;

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const words = (post.body ?? '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 238));

let ogImageUrl: string | undefined;
if (post.data.coverImage) {
  const processed = await getImage({
    src: post.data.coverImage,
    width: 1200,
    height: 630,
    format: 'png',
  });
  ogImageUrl = new URL(processed.src, Astro.site).toString();
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    websiteRef,
    {
      '@type': 'WebPage',
      '@id': `https://hawksley.dev/blog/${post.id}/#webpage`,
      url: `https://hawksley.dev/blog/${post.id}/`,
      name: post.data.title,
      isPartOf: { '@id': 'https://hawksley.dev/#website' },
      inLanguage: 'en-GB',
      breadcrumb: { '@id': `https://hawksley.dev/blog/${post.id}/#breadcrumb` },
    },
    {
      '@type': 'Blog',
      '@id': 'https://hawksley.dev/blog/#blog',
      url: 'https://hawksley.dev/blog/',
      name: "Ethan Hawksley's Blog",
      publisher: { '@id': 'https://hawksley.dev/#person' },
      inLanguage: 'en-GB',
    },
    {
      '@type': 'BlogPosting',
      '@id': `https://hawksley.dev/blog/${post.id}/#article`,
      mainEntityOfPage: {
        '@id': `https://hawksley.dev/blog/${post.id}/#webpage`,
      },
      url: `https://hawksley.dev/blog/${post.id}/`,
      headline: post.data.title,
      description: post.data.description,
      image: {
        '@type': 'ImageObject',
        '@id': ogImageUrl ?? 'https://hawksley.dev/og-image-1200x630.png',
        url: ogImageUrl ?? 'https://hawksley.dev/og-image-1200x630.png',
        width: 1200,
        height: 630,
      },
      datePublished: post.data.pubDate.toISOString(),
      dateModified:
        post.data.modDate?.toISOString() ?? post.data.pubDate.toISOString(),
      author: { '@id': 'https://hawksley.dev/#person' },
      publisher: { '@id': 'https://hawksley.dev/#person' },
      isPartOf: { '@id': 'https://hawksley.dev/blog/#blog' },
      keywords: post.data.tags,
      articleSection: post.data.tags[0] ?? 'Computer Science',
      inLanguage: 'en-GB',
      license: 'https://creativecommons.org/licenses/by/4.0/',
    },
    personRef,
    {
      '@type': 'BreadcrumbList',
      '@id': `https://hawksley.dev/blog/${post.id}/#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://hawksley.dev/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Blog',
          item: 'https://hawksley.dev/blog/',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: post.data.title,
          item: `https://hawksley.dev/blog/${post.id}/`,
        },
      ],
    },
  ],
};
---

<Layout
  title={`${post.data.title} | Ethan Hawksley`}
  description={post.data.description}
  jsonLd={jsonLd}
  ogType="article"
  ogImage={ogImageUrl}
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: post.data.modDate?.toISOString(),
    tags: post.data.tags,
    readingTime,
  }}
>
  <Fragment slot="svg-symbols">
    <symbol
      id="icon-copy"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="9" y="9" width="13" height="13" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </symbol>
    <symbol
      id="icon-check"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </symbol>
  </Fragment>

  <nav aria-label="Back to blog" class="breadcrumb">
    <A href="/blog/" style="text-decoration: none;" pressable>
      <span aria-hidden="true">←</span> Back to blog
    </A>
  </nav>
  <article id="post">
    <header>
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <span>
          Published <FormattedDate date={post.data.pubDate} />
        </span>
        ·
        {
          post.data.modDate && (
            <>
              <span>
                Modified <FormattedDate date={post.data.modDate} />
              </span>
              ·
            </>
          )
        }
        <span>{readingTime} min read</span>
        {
          post.data.tags.length > 0 && (
            <>
              ·<span>{post.data.tags.join(', ')}</span>
            </>
          )
        }
      </div>
    </header>
    <div class="content">
      <Content components={{ a: A, img: BlogImage }} />
    </div>
  </article>
  <nav class="post-nav" aria-label="Post navigation">
    <div class="nav-prev">
      {
        prevPost && (
          <A href={`/blog/${prevPost.id}/`} style="text-decoration: none;">
            <span class="arrow" aria-hidden="true">
              ←
            </span>
            <span class="sr-only">Previous post:</span>
            <span class="nav-title">{prevPost.data.title}</span>
          </A>
        )
      }
    </div>
    <div class="nav-next">
      {
        nextPost && (
          <A href={`/blog/${nextPost.id}/`} style="text-decoration: none;">
            <span class="sr-only">Next post:</span>
            <span class="nav-title">{nextPost.data.title}</span>
            <span class="arrow" aria-hidden="true">
              →
            </span>
          </A>
        )
      }
    </div>
    <div class="nav-all">
      <A href="/blog/" pressable>View all posts</A>
    </div>
  </nav>
</Layout>
<style is:global>
  .content {
    inline-size: 100%;
    min-inline-size: 0;

    > :first-child {
      margin-block-start: 0;
    }

    > :last-child {
      margin-block-end: 0;
    }

    h2,
    h3,
    h4,
    h5,
    h6,
    p,
    li,
    blockquote {
      max-inline-size: 65ch;
    }

    p,
    li {
      line-height: var(--leading-relaxed);
    }

    p,
    ul,
    ol {
      margin-block: 1.5rem;
      font-size: var(--font-size-base);
    }

    li + li {
      margin-block-start: 0.5rem;
    }

    li > ul,
    li > ol {
      margin-block: 0.5rem 0;
    }

    h2 {
      font-size: var(--font-size-lg);
      line-height: var(--leading-snug);
      letter-spacing: var(--tracking-snug);
      margin-block-start: 2.5rem;
      margin-block-end: 0.75rem;
    }

    h3 {
      font-size: var(--font-size-md);
      margin-block-start: 2rem;
      margin-block-end: 0.5rem;
    }

    h4 {
      margin-block-start: 1.5rem;
      margin-block-end: 0.5rem;
    }

    h5,
    h6 {
      margin-block-start: 1.25rem;
      margin-block-end: 0.25rem;
    }

    li {
      font-size: var(--font-size-base);
    }

    img {
      border-radius: 1rem;
    }

    blockquote {
      border-inline-start: 4px solid var(--color-accent);
      background: var(--color-surface);
      color: var(--color-text-muted);
      padding-block: 1rem;
      padding-inline: 1.5rem;
      border-start-end-radius: 0.5rem;
      border-end-end-radius: 0.5rem;
      font-style: italic;
    }

    blockquote > :first-child {
      margin-block-start: 0;
    }

    blockquote > :last-child {
      margin-block-end: 0;
    }
  }

  code {
    font-family: var(--font-mono);
    font-variant-numeric: slashed-zero;
  }

  .astro-code {
    position: relative;
    border: 2px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.5rem;
    overflow-inline: auto;
    overscroll-behavior-inline: contain;
    inline-size: 100%;
    max-inline-size: 100%;
    display: grid;
  }

  .astro-code:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .astro-code code {
    display: block;
    min-inline-size: max-content;
    font-size: var(--font-size-xs);
    grid-area: 1/1;
  }

  @media (min-width: 40rem) {
    .astro-code code {
      font-size: var(--font-size-sm);
    }
  }

  .astro-code {
    color: light-dark(var(--shiki-light), var(--shiki-dark));
    background-color: light-dark(var(--shiki-light-bg), var(--shiki-dark-bg));
  }

  .astro-code span {
    color: light-dark(var(--shiki-light), var(--shiki-dark));
    font-style: var(--shiki-light-font-style);
    font-weight: var(--shiki-light-font-weight);
    text-decoration: var(--shiki-light-text-decoration);
  }

  [data-theme='dark'] .astro-code span {
    font-style: var(--shiki-dark-font-style);
    font-weight: var(--shiki-dark-font-weight);
    text-decoration: var(--shiki-dark-text-decoration);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .astro-code span {
      font-style: var(--shiki-dark-font-style);
      font-weight: var(--shiki-dark-font-weight);
      text-decoration: var(--shiki-dark-text-decoration);
    }
  }

  .copy-button {
    grid-area: 1 / 1;
    justify-self: start;
    align-self: start;
    position: sticky;
    inset-block-start: 0.5rem;
    inset-inline-start: calc(100% - 2.5rem);
    padding: 0.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-surface);
    color: var(--color-text-muted);
    opacity: 0;
    display: none;
    z-index: 10;
  }

  .js .copy-button {
    display: flex;
  }

  pre.astro-code:hover .copy-button,
  pre.astro-code:focus-within .copy-button {
    opacity: 1;
  }

  .copy-button:hover {
    color: var(--color-accent);
  }

  .copy-button .check-icon {
    display: none;
  }

  .copy-button[data-copied] .copy-icon {
    display: none;
  }

  .copy-button[data-copied] .check-icon {
    display: block;
    color: #22c55e;
  }

  @media (hover: none) {
    .copy-button {
      opacity: 1;
    }
  }
</style>

<style>
  .breadcrumb {
    margin-block-end: 0.5rem;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    inline-size: 100%;
  }

  article {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    inline-size: 100%;
    min-inline-size: 0;

    header {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding-block-end: 1.5rem;
      border-block-end: 1px solid var(--color-border);
    }

    .post-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
      font-family: var(--font-mono);
      font-variant-numeric: tabular-nums;
    }
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-block-start: 2.5rem;
    padding-block-start: 1.5rem;
    border-block-start: 1px solid var(--color-border);
    inline-size: 100%;
  }

  .nav-prev :global(a),
  .nav-next :global(a) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
  }

  .nav-next :global(a) {
    justify-content: flex-end;
    text-align: end;
  }

  .arrow {
    flex-shrink: 0;
  }

  .nav-title {
    text-decoration: var(--color-accent) underline 2px;
    text-underline-offset: 0.25em;
  }

  .nav-all {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (min-width: 40rem) {
    .post-nav {
      grid-template-columns: 1fr 1fr;
    }

    .nav-all {
      grid-column: 1 / -1;
    }
  }
</style>

<script>
  const timeouts = new WeakMap<
    HTMLButtonElement,
    ReturnType<typeof setTimeout>
  >();

  function initCopyButtons() {
    const controller = new AbortController();

    document.addEventListener(
      'click',
      async (e: MouseEvent) => {
        const button = (e.target as HTMLElement).closest<HTMLButtonElement>(
          '.copy-button',
        );
        if (!button) return;
        const code = button
          .closest('pre')
          ?.querySelector('code')
          ?.textContent?.trimEnd();
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code);
        } catch {
          return;
        }
        button.dataset.copied = '';
        button.setAttribute('aria-label', 'Copied!');
        const prev = timeouts.get(button);
        if (prev) clearTimeout(prev);
        timeouts.set(
          button,
          setTimeout(() => {
            delete button.dataset.copied;
            button.setAttribute('aria-label', 'Copy code');
          }, 2000),
        );
      },
      { signal: controller.signal },
    );

    document.addEventListener('astro:before-swap', () => controller.abort(), {
      once: true,
    });
  }

  document.addEventListener('astro:page-load', initCopyButtons);
</script>
