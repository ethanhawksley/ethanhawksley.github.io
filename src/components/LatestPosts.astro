---
import A from './A.astro';
import PostPreview from './PostPreview.astro';
import { getSortedPosts } from '../utils/content-helpers';

const allPosts = await getSortedPosts();
const postCount = allPosts.length;
---

<span class="machine-only">
  Showing the 2 most recent of {postCount} posts. Full index at https://hawksley.dev/blog/
</span>
<ul class="blog-preview" role="list">
  {
    allPosts
      .slice(0, 2)
      .map((post) => (
        <PostPreview
          href={`/blog/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          headingLevel="h3"
        />
      ))
  }
</ul>
<A href="/blog/" pressable>View all posts</A>

<style>
  .blog-preview {
    display: flex;
    flex-direction: column;
    inline-size: 100%;
  }

  .machine-only {
    display: none;
  }
</style>
