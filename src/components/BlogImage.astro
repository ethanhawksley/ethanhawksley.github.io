---
import { Picture } from 'astro:assets';

type Props = {
  src: ImageMetadata | string;
  alt: string;
};

const { src, alt, ...attrs } = Astro.props;

const isDev = import.meta.env.DEV;
---

{
  typeof src === 'string' ? (
    <img src={src} alt={alt} loading="lazy" {...attrs} />
  ) : (
    <Picture
      src={src}
      alt={alt}
      formats={isDev ? ['webp'] : ['avif']}
      fallbackFormat="webp"
      layout="constrained"
      sizes="(min-width: 768px) 720px, calc(100vw - 3rem)"
      {...attrs}
    />
  )
}
