---
import type { HTMLAttributes } from 'astro/types';

const protocols = new Set(['http:', 'https:']);
const hostnames = new Set([
  'hawksley.dev',
  'www.hawksley.dev',
  '127.0.0.1',
  'localhost',
]);
const exactPaths = new Set(['/', '/rss.xml/', '/elsewhere/']);
const pathPrefixes = new Set(['/blog/']);

interface Props extends HTMLAttributes<'a'> {
  href: string;
  rel?: string;
  style?: string;
  pressable?: boolean;
  external?: boolean;
}
const { href, rel, style, pressable, external, ...rest } = Astro.props;

function isExternal(linkHref: string) {
  // All https links that are not explicitly part of this blog should be external.
  // Links on the same domain could be different projects, so must be external too.
  const url = new URL(linkHref, 'https://hawksley.dev');

  // Treat unknown protocols as internal
  if (!protocols.has(url.protocol)) return false;

  if (!hostnames.has(url.hostname)) return true;

  let path = url.pathname;
  if (!path.endsWith('/')) {
    path += '/';
  }

  if (exactPaths.has(path)) return false;

  for (const prefix of pathPrefixes) {
    if (path.startsWith(prefix)) return false;
  }

  return true;
}

const isExternalLink = external !== undefined ? external : isExternal(href);
---

<a
  href={href}
  target={isExternalLink ? '_blank' : undefined}
  rel={rel || (isExternalLink ? 'noopener noreferrer' : undefined)}
  style={style}
  data-pressable={pressable || undefined}
  {...rest}
  ><span><slot /></span>{
    isExternalLink && (
      <svg width="14" height="14" role="img" aria-label="(opens in a new tab)">
        <use href="#icon-external" />
      </svg>
    )
  }</a
>

<style>
  a {
    color: inherit;
    text-decoration: var(--color-accent) underline 2px;
    text-underline-offset: 0.25em;
    white-space: nowrap;
  }

  a:hover {
    color: var(--color-accent);
  }

  a:active {
    transform: scale(0.96);
  }

  a[data-pressable] {
    display: inline-block;
  }

  span {
    white-space: normal;
  }

  a svg {
    display: inline-block;
    inline-size: 0.75em;
    block-size: 0.75em;
    margin-inline-start: 0.15em;
    vertical-align: baseline;
    transition: transform 250ms ease-out !important;
  }

  a:hover svg {
    transform: translate(0.15em, -0.15em);
  }
</style>
