---
import type { HTMLAttributes } from 'astro/types';
import { getInternalUrls } from '../utils/site-urls';

const protocols = new Set(['http:', 'https:']);
const localHostnames = new Set(['127.0.0.1', 'localhost']);
const internalUrls = new Set(await getInternalUrls());

interface Props extends HTMLAttributes<'a'> {
  href: string;
  pressable?: boolean;
  external?: boolean;
}
const { href, rel, style, pressable, external, ...rest } = Astro.props;

function isExternal(linkHref: string) {
  // All https links that are not explicitly part of this blog should be external.
  // Links on the same domain could be different projects, so must be external too.
  const url = new URL(linkHref, Astro.url);

  // Treat unknown protocols as internal
  if (!protocols.has(url.protocol)) return false;

  // Treat 127.0.0.1 and localhost as internal
  if (localHostnames.has(url.hostname)) {
    return false;
  }

  url.protocol = 'https:';
  url.port = '';
  url.search = '';
  url.hash = '';

  return !internalUrls.has(url.toString());
}

const isExternalLink = external ?? isExternal(href);
---

<a
  href={href}
  target={isExternalLink ? '_blank' : undefined}
  rel={rel || (isExternalLink ? 'noopener noreferrer' : undefined)}
  style={style}
  data-pressable={pressable || undefined}
  {...rest}
  ><span
    ><slot />{
      isExternalLink && <span class="sr-only">, opens in new tab</span>
    }</span
  >{
    isExternalLink && (
      <svg width="14" height="14" aria-hidden="true">
        <use href="#icon-external" />
      </svg>
    )
  }
</a>

<style>
  a {
    color: var(--color-text);
    white-space: nowrap;
    text-decoration: none;
  }

  a:hover {
    color: var(--color-accent);
  }

  a:active {
    transform: scale(0.96);
  }

  a[data-pressable] {
    display: inline-block;
  }

  span {
    white-space: normal;
    text-decoration: var(--color-accent) underline 2px;
    text-underline-offset: 0.25em;
    transition: text-decoration-color 250ms ease-out !important;
  }

  a svg {
    display: inline-block;
    inline-size: 0.75em;
    block-size: 0.75em;
    margin-inline-start: 0.15em;
    vertical-align: baseline;
    transition: transform 250ms ease-out !important;
  }

  a:hover svg {
    transform: translate(0.15em, -0.15em);
  }

  @media print {
    a svg {
      display: none !important;
    }
  }
</style>
