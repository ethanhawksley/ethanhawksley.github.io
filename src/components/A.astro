---
import type { HTMLAttributes } from 'astro/types';

const protocols = new Set(['http:', 'https:']);
const hostnames = new Set([
  'hawksley.dev',
  'www.hawksley.dev',
  '127.0.0.1',
  'localhost',
]);
const exactPaths = new Set(['/', '/404/', '/rss.xml/']);
const pathPrefixes = new Set(['/blog/']);

interface Props extends HTMLAttributes<'a'> {
  href: string;
  rel?: string;
  style?: string;
}
const { href, rel, style, ...rest } = Astro.props;

function isExternal(linkHref: string) {
  // All https links that are not explicitly part of this blog should be external.
  // Links on the same domain could be different projects, so must be external too.
  const url = new URL(linkHref, 'https://hawksley.dev');

  // Treat unknown protocols as internal
  if (!protocols.has(url.protocol)) return false;

  if (!hostnames.has(url.hostname)) return true;

  let path = url.pathname;
  if (!path.endsWith('/')) {
    path += '/';
  }

  if (exactPaths.has(path)) return false;

  for (const prefix of pathPrefixes) {
    if (path.startsWith(prefix)) return false;
  }

  return true;
}
const isExternalLink = isExternal(href);
---

<a
  href={href}
  rel={[isExternalLink && 'noopener noreferrer', rel]
    .filter(Boolean)
    .join(' ') || undefined}
  target={isExternalLink ? '_blank' : undefined}
  style={style}
  {...rest}
>
  <slot />
  {
    isExternalLink && (
      <>
        <svg width="14" height="14" aria-hidden="true">
          <use href="#icon-external" />
        </svg>
        <span class="sr-only">(opens in a new tab)</span>
      </>
    )
  }
</a>

<style>
  a {
    color: inherit;
    text-decoration: var(--color-accent) underline 2px;
    text-underline-offset: 0.25em;
    transition:
      color 250ms ease-out,
      transform 250ms ease-out;
    display: inline-flex;
    align-items: center;
    text-wrap: auto;
    gap: 0.15em;
  }

  a:hover {
    color: var(--color-accent);
  }

  a svg {
    transition: transform 0.2s ease-out;
    width: 0.75em;
    height: 0.75em;
    margin-right: -0.15em;
  }

  a:hover svg {
    transform: translate(2px, -2px);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }
</style>
