---
import Moon from '../assets/moon.svg';
import Sun from '../assets/sun.svg';
---

<button id="theme-toggle" aria-label="Toggle theme" aria-pressed="false">
  <Moon class="moon" aria-hidden="true" focusable="false" />
  <Sun class="sun" aria-hidden="true" focusable="false" />
  <noscript>
    <style>
      button {
        display: none !important;
      }
    </style>
  </noscript>
</button>

<style>
  @property --hover-mix {
    syntax: '<percentage>';
    inherits: false;
    initial-value: 0%;
  }

  button {
    border: 0;
    background: none;
    cursor: pointer;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .sun,
  .moon {
    transition:
      --hover-mix 250ms ease-out,
      opacity 250ms ease-out;

    color: color-mix(
      in srgb,
      var(--color-accent) var(--hover-mix),
      var(--color-text)
    );

    width: 2rem;
    height: 2rem;
    position: absolute;
  }

  .sun {
    opacity: 0;
  }

  :global(.dark) .moon {
    opacity: 0;
  }

  :global(.dark) .sun {
    opacity: 1;
  }

  button:hover > .sun,
  button:hover > .moon {
    --hover-mix: 100%;
  }
</style>

<script>
  function initThemeToggle() {
    const button = document.getElementById('theme-toggle');
    if (!button) return;

    function updateState(isDark: boolean) {
      button?.setAttribute('aria-pressed', String(isDark));
      document.head
        .querySelectorAll('meta[name="theme-color"]')
        .forEach((tag) => {
          tag.setAttribute('content', isDark ? '#0f0f0f' : '#fafafa');
        });
      document.head
        .querySelector('meta[name="color-scheme"]')
        ?.setAttribute('content', isDark ? 'dark' : 'light');
    }

    updateState(document.documentElement.classList.contains('dark'));

    button.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      document.documentElement.classList.toggle('light', !isDark);
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch {}
      updateState(isDark);
    });

    const controller = new AbortController();

    window.addEventListener(
      'storage',
      (e) => {
        if (e.key === 'theme') {
          const isDark = e.newValue === 'dark';
          document.documentElement.classList.toggle('dark', isDark);
          document.documentElement.classList.toggle('light', !isDark);
          updateState(isDark);
        }
      },
      { signal: controller.signal },
    );

    document.addEventListener('astro:before-swap', () => controller.abort(), {
      once: true,
    });
  }

  document.addEventListener('astro:page-load', initThemeToggle);
</script>
