---
import Moon from '../assets/moon.svg';
import Sun from '../assets/sun.svg';
---

<button
  type="button"
  id="theme-toggle"
  aria-label="Toggle theme"
  aria-pressed="false"
>
  <Moon class="moon" aria-hidden="true" />
  <Sun class="sun" aria-hidden="true" />
</button>

<style>
  @property --hover-mix {
    syntax: '<percentage>';
    inherits: false;
    initial-value: 0%;
  }

  button {
    width: 3rem;
    height: 3rem;
    align-items: center;
    justify-content: center;
    position: relative;
    display: none;
  }

  :global(.js) button {
    display: flex;
  }

  .sun,
  .moon {
    transition:
      --hover-mix 250ms ease-out,
      opacity 250ms ease-out;

    color: color-mix(
      in srgb,
      var(--color-accent) var(--hover-mix),
      var(--color-text)
    );

    width: 2rem;
    height: 2rem;
    position: absolute;
  }

  .sun {
    opacity: 0;
  }

  :global([data-theme='dark']) .moon {
    opacity: 0;
  }

  :global([data-theme='dark']) .sun {
    opacity: 1;
  }

  @media (hover: hover) {
    button:hover > .sun,
    button:hover > .moon {
      --hover-mix: 100%;
    }
  }
</style>

<script>
  const mediaQuery = matchMedia('(prefers-color-scheme: dark)');

  function initThemeToggle() {
    const button = document.getElementById('theme-toggle')!;

    function updateState(isDark: boolean) {
      button.setAttribute('aria-pressed', String(isDark));
      document.head
        .querySelectorAll('meta[name="theme-color"]')
        .forEach((tag) => {
          tag.setAttribute('content', isDark ? '#0f0f0f' : '#fafafa');
        });
    }

    updateState(document.documentElement.getAttribute('data-theme') === 'dark');

    button.addEventListener('click', () => {
      const isDark =
        document.documentElement.getAttribute('data-theme') === 'dark';
      const nextTheme = isDark ? 'light' : 'dark';

      document.documentElement.setAttribute('data-theme', nextTheme);
      try {
        localStorage.setItem('theme', nextTheme);
      } catch {}
      updateState(!isDark);
    });

    const controller = new AbortController();

    window.addEventListener(
      'storage',
      (e) => {
        if (e.key === 'theme') {
          const isDark =
            e.newValue === 'dark' ||
            (e.newValue === null && mediaQuery.matches);

          document.documentElement.setAttribute(
            'data-theme',
            isDark ? 'dark' : 'light',
          );
          updateState(isDark);
        }
      },
      { signal: controller.signal },
    );

    const handlePreferenceChange = (e: MediaQueryListEvent) => {
      try {
        if (localStorage.getItem('theme') !== null) return;
      } catch {}

      const isDark = e.matches;
      document.documentElement.setAttribute(
        'data-theme',
        isDark ? 'dark' : 'light',
      );
      updateState(isDark);
    };

    mediaQuery.addEventListener('change', handlePreferenceChange, {
      signal: controller.signal,
    });

    document.addEventListener('astro:before-swap', () => controller.abort(), {
      once: true,
    });
  }

  document.addEventListener('astro:page-load', initThemeToggle);
</script>
