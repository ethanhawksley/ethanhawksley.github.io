---
import A from './A.astro';

interface ProjectLink {
  name: string;
  url: string;
}

interface Props {
  name: string;
  description: string;
  url: string;
  links?: ProjectLink[];
  type: 'Web' | 'CLI' | 'Tool';
  stack: string[];
}

const { name, description, links = [], url, type, stack } = Astro.props;
---

<li>
  <article>
    <h3>
      {
        (
          <A href={url} pressable>
            {name}
          </A>
        )
      }
    </h3>
    <p>{description}</p>
    <footer>
      <span class="meta">
        <span class="type">{type}</span>
        {
          stack.length > 0 && (
            <>
              <span class="separator" aria-hidden="true">
                /
              </span>
              <span class="sr-only">Stack: </span>
              <span>{stack.join(', ')}</span>
            </>
          )
        }
      </span>
      {
        links.map((link) => (
          <span class="meta-action">
            <A href={link.url} pressable>
              <span class="sr-only">View {name} </span>
              {link.name}
            </A>
          </span>
        ))
      }
    </footer>
  </article>
</li>

<style>
  li + li {
    border-block-start: 1px solid var(--color-border);
  }

  article {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-block: 1.5rem;
    padding-inline: 0;
  }

  p {
    max-inline-size: 65ch;
    color: var(--color-text-muted);
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    margin-block-start: 0.25rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    font-variant-numeric: tabular-nums;
  }

  .meta {
    display: flex;
    gap: 0.5rem;
    color: var(--color-text-muted);
  }

  .type {
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .separator {
    margin-inline: 0.25rem;
  }

  .meta-action :global(a) {
    font-weight: var(--weight-medium);
  }
</style>
