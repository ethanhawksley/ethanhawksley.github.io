---
import A from './A.astro';

interface Props {
  name: string;
  description: string;
  sourceUrl?: string;
  liveUrl?: string;
  type: 'Web' | 'CLI' | 'Tool';
  stack: string[];
}

const { name, description, sourceUrl, liveUrl, type, stack } = Astro.props;
---

<li>
  <article>
    <h3><A href={sourceUrl} pressable>{name}</A></h3>
    <p>{description}</p>
    <footer>
      <span class="meta-data">
        <span class="type">{type}</span>
        {
          stack.length > 0 && (
            <span class="separator" aria-hidden="true">
                /
              </span>
            <span>
              {stack.join(', ')}
            </span>
          )
        }
      </span>
      {
        liveUrl && (
          <span class="meta-action">
            <A href={liveUrl} aria-label={`View ${name} live`} pressable>
              {'View Live'}
            </A>
          </span>
        )
      }
    </footer>
  </article>
</li>

<style>
  li {
    inline-size: 100%;
  }

  li + li {
    border-block-start: 1px solid var(--color-border);
  }

  article {
    padding-block: 1.5rem;
    padding-inline: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  h3 {
    font-size: var(--font-size-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    margin: 0;
  }

  p {
    color: var(--color-text-muted);
    font-size: var(--font-size-base);
    margin: 0;
    max-inline-size: 65ch;
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    margin-block-start: 0.25rem;
    font-size: var(--font-size-sm);

    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }

  .meta-data {
    color: var(--color-text-muted);
    display: flex;
    gap: 0.5rem;
  }

  .type {
    color: var(--color-text);
    font-weight: var(--weight-semibold);
  }

  .separator {
    color: var(--color-muted);
    margin-inline: 0.25rem;
  }

  .meta-action :global(a) {
    font-weight: var(--weight-medium);
  }
</style>
