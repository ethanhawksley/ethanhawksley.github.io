---
import A from './A.astro';

interface Props {
  name: string;
  description: string;
  sourceUrl?: string;
  liveUrl?: string;
  type: 'Web' | 'CLI' | 'Tool';
  stack: string[];
}

const { name, description, sourceUrl, liveUrl, type, stack } = Astro.props;

const projectUrl = liveUrl ?? sourceUrl;
---

<li>
  <article>
    <h3>
      {
        projectUrl ? (
          <A href={projectUrl} pressable>
            {name}
          </A>
        ) : (
          name
        )
      }
    </h3>
    <p>{description}</p>
    <footer>
      <span class="meta">
        <span class="type">{type}</span>
        {
          stack.length > 0 && (
            <>
              <span class="separator" aria-hidden="true">
                /
              </span>
              <span>{stack.join(', ')}</span>
            </>
          )
        }
      </span>
      {
        sourceUrl && (
          <span class="meta-action">
            <A
              href={sourceUrl}
              aria-label={`View source code for ${name}`}
              pressable
            >
              {'Source'}
            </A>
          </span>
        )
      }
    </footer>
  </article>
</li>

<style>
  li {
    inline-size: 100%;
  }

  li + li {
    border-block-start: 1px solid var(--color-border);
  }

  article {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-block: 1.5rem;
    padding-inline: 0;
  }

  p {
    max-inline-size: 65ch;
    color: var(--color-text-muted);
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-block-start: 0.25rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    font-variant-numeric: tabular-nums;
  }

  .meta {
    display: flex;
    gap: 0.5rem;
    color: var(--color-text-muted);
  }

  .type {
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .separator {
    margin-inline: 0.25rem;
  }

  .meta-action :global(a) {
    font-weight: var(--weight-medium);
  }
</style>
