---
import LogoRound from '../assets/logo_round.svg';
import ThemeToggle from './ThemeToggle.astro';

const isHome = Astro.url.pathname === '/';
const isBlogIndex = Astro.url.pathname === '/blog/';
const isBlog = Astro.url.pathname.startsWith('/blog/');
---

<header>
  <nav aria-label="Main navigation">
    <a href="/" aria-label="Home - Ethan Hawksley" class="logo"
      ><LogoRound width="3rem" height="3rem" aria-hidden="true" /></a
    >
    <div class="page-links">
      <a
        href="/"
        class:list={[{ active: isHome }]}
        aria-current={isHome ? 'page' : undefined}
      >
        Home</a
      >
      <a
        href="/blog/"
        class:list={[{ active: isBlog }]}
        aria-current={isBlogIndex ? 'page' : isBlog ? 'true' : undefined}
      >
        Blog</a
      >
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  nav {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    min-block-size: 3rem;
    block-size: auto;
    flex-wrap: wrap;
    padding-inline: 1.5rem;
  }

  .logo {
    inline-size: 3rem;
    block-size: 3rem;
  }

  .page-links {
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
  }

  .page-links a {
    padding-block: 0.75rem;
    padding-inline: 0.25rem;
    margin-block: -0.75rem;
    margin-inline: -0.25rem;
  }

  a {
    color: inherit;
    text-decoration: none;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: var(--font-size-base);
    line-height: var(--leading-tight);
  }

  .active {
    text-decoration: var(--color-accent) underline 2px;
    text-underline-offset: 0.25em;
  }

  .active,
  a:hover {
    color: var(--color-accent);
  }

  a:active {
    transform: scale(0.96);
  }
</style>
