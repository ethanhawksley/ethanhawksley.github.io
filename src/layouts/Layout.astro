---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  jsonLd?: Record<string, any>;
  robots?: string;
  ogType?: 'website' | 'article' | 'profile';
  ogImage?: string;
  article?: {
    publishedTime: string;
    modifiedTime?: string;
    tags: string[];
    readingTime: number;
  };
}

const {
  title,
  description,
  jsonLd,
  robots = 'max-image-preview:large, max-snippet:-1',
  ogType = 'website',
  ogImage = 'https://hawksley.dev/og-image-1200x630-v2.png',
  article,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const isIndexable = !robots.includes('noindex');

const isHome = Astro.url.pathname === '/';
---

<html lang="en-GB" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      rel="preload"
      href="/fonts/IBMSans-Subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/fonts/IBMMono-Subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{title}</title>

    <meta
      name="theme-color"
      content="#fafafa"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0f0f0f"
      media="(prefers-color-scheme: dark)"
    />

    <script is:inline>
      {
        const theme =
          (() => {
            try {
              return localStorage.getItem('theme');
            } catch {
              return null;
            }
          })() ||
          (matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.classList.add('js');
        const color = theme === 'dark' ? '#0f0f0f' : '#fafafa';
        document.head
          .querySelectorAll('meta[name="theme-color"]')
          .forEach((tag) => {
            tag.setAttribute('content', color);
            tag.removeAttribute('media');
          });
        if (
          navigator.userAgent.includes('Chrome') ||
          navigator.userAgent.includes('Edg')
        ) {
          document.startViewTransition = undefined;
        }
      }
    </script>

    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="format-detection" content="telephone=no" />
    <meta name="color-scheme" content="light dark" />

    {
      isIndexable && (
        <>
          <link rel="canonical" href={canonicalUrl} />

          <meta property="og:type" content={ogType} />
          <meta property="og:url" content={canonicalUrl} />
          <meta property="og:title" content={title} />
          <meta property="og:description" content={description} />
          <meta property="og:site_name" content="Ethan Hawksley" />
          <meta property="og:locale" content="en_GB" />
          <meta property="og:image" content={ogImage} />
          <meta property="og:image:alt" content={title} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta property="og:image:type" content="image/png" />

          {ogType === 'profile' && (
            <>
              <meta property="profile:first_name" content="Ethan" />
              <meta property="profile:last_name" content="Hawksley" />
            </>
          )}

          <meta name="twitter:card" content="summary_large_image" />
          <meta name="twitter:site" content="@Ethan_Hawksley" />
          <meta name="twitter:creator" content="@Ethan_Hawksley" />
          <meta name="twitter:title" content={title} />
          <meta name="twitter:description" content={description} />
          <meta name="twitter:image" content={ogImage} />
          <meta name="twitter:image:alt" content={title} />

          {article && (
            <>
              <meta name="twitter:label1" content="Author" />
              <meta name="twitter:data1" content="Ethan Hawksley" />
              <meta name="twitter:label2" content="Reading time" />
              <meta
                name="twitter:data2"
                content={`${article.readingTime} min read`}
              />

              <meta
                property="article:published_time"
                content={article.publishedTime}
              />
              {article.modifiedTime && (
                <meta
                  property="article:modified_time"
                  content={article.modifiedTime}
                />
              )}
              {article.tags.map((tag) => (
                <meta property="article:tag" content={tag} />
              ))}
            </>
          )}

          <meta
            name="fediverse:creator"
            content="@ethanhawksley@mastodon.social"
          />
        </>
      )
    }

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      href="/rss.xml"
      type="application/rss+xml"
      title="Ethan Hawksley's Blog"
    />
    <link
      rel="alternate"
      href="/feed.json"
      type="application/feed+json"
      title="Ethan Hawksley's Blog"
    />

    <link rel="icon" href="/favicon-v2.svg" type="image/svg+xml" />
    <link
      rel="icon"
      href="/favicon-48x48-v2.png"
      type="image/png"
      sizes="48x48"
    />
    <link rel="icon" href="/favicon-v2.ico" type="image/x-icon" />
    <link
      rel="apple-touch-icon"
      href="/apple-touch-icon-v2.png"
      sizes="180x180"
    />
    <link rel="manifest" href="/site-v2.webmanifest" />
    <meta name="apple-mobile-web-app-title" content="Hawksley" />

    {
      isHome && (
        <>
          <link rel="me" href="https://github.com/ethan-hawksley" />
          <link rel="me" href="https://mastodon.social/@ethanhawksley" />
        </>
      )
    }

    {
      jsonLd && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(jsonLd).replaceAll('<', '\\u003c')}
        />
      )
    }

    <ClientRouter />
  </head>
  <body>
    <svg xmlns="http://www.w3.org/2000/svg" style="display:none">
      <symbol
        id="icon-external"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M7 17 17 7m0 0H7m10 0v10"></path>
      </symbol>
      <slot name="svg-symbols" />
    </svg>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="page">
      <div class="nav-bar">
        <Navigation />
      </div>
      <main id="main-content" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      function syncMeta(doc: Document) {
        const isDark =
          doc.documentElement.getAttribute('data-theme') === 'dark';
        const color = isDark ? '#0f0f0f' : '#fafafa';
        doc.head.querySelectorAll('meta[name="theme-color"]').forEach((tag) => {
          tag.setAttribute('content', color);
          tag.removeAttribute('media');
        });
      }

      document.addEventListener('astro:before-swap', (event) => {
        const theme =
          document.documentElement.getAttribute('data-theme') || 'light';

        event.newDocument.documentElement.setAttribute('data-theme', theme);
        event.newDocument.documentElement.classList.add('js');

        syncMeta(event.newDocument);
      });

      document.addEventListener('astro:after-swap', () => {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            document.documentElement.classList.add('enable-transitions');
          });
        });
      });

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          document.documentElement.classList.add('enable-transitions');
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;

    --color-background: light-dark(#fafafa, #0f0f0f);
    --color-surface: light-dark(#eaeaea, #1f1f1f);
    --color-text: light-dark(#1a1a1a, #ededed);
    --color-text-muted: light-dark(#525252, #b0b0b0);
    --color-accent: light-dark(#bf3900, #ff4f00);
    --color-border: light-dark(#e0e0e0, #2a2a2a);
    --color-selection: light-dark(#bf3900, #b33800);

    --font-size-xs: clamp(0.75rem, 0.7083rem + 0.2083vi, 0.875rem);
    --font-size-sm: clamp(0.875rem, 0.8333rem + 0.2083vi, 1rem);
    --font-size-base: clamp(1rem, 0.9583rem + 0.2083vi, 1.125rem);
    --font-size-md: clamp(1.1875rem, 1.1042rem + 0.4167vi, 1.4375rem);
    --font-size-lg: clamp(1.375rem, 1.25rem + 0.625vi, 1.75rem);
    --font-size-xl: clamp(1.625rem, 1.4167rem + 1.0417vi, 2.25rem);
    --font-size-2xl: clamp(2rem, 1.6667rem + 1.6667vi, 3rem);

    --leading-tight: 1.15;
    --leading-snug: 1.25;
    --leading-normal: 1.5;
    --leading-relaxed: 1.6;

    --tracking-tight: -0.025em;
    --tracking-snug: -0.015em;
    --tracking-normal: -0.01em;

    --weight-normal: 400;
    --weight-medium: 500;
    --weight-semibold: 600;

    --font-sans: 'IBM Sans Subset', system-ui, sans-serif;
    --font-mono: 'IBM Mono Subset', ui-monospace, monospace;

    --img-theme-filter: none;
  }

  :root[data-theme='light'] {
    color-scheme: light;
  }

  :root[data-theme='dark'] {
    color-scheme: dark;
    --img-theme-filter: opacity(0.85) contrast(1.1);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) {
      --img-theme-filter: opacity(0.85) contrast(1.1);
    }
  }

  @font-face {
    font-family: 'IBM Sans Subset';
    font-style: normal;
    font-weight: 100 700;
    font-display: swap;
    src: url('/fonts/IBMSans-Subset.woff2') format('woff2');
  }

  @font-face {
    font-family: 'IBM Mono Subset';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('/fonts/IBMMono-Subset.woff2') format('woff2');
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  * {
    margin: 0;
  }

  ul[role='list'],
  ol[role='list'] {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  html {
    background-color: var(--color-background);
    color: var(--color-text);
    font-family: var(--font-sans);
    accent-color: var(--color-accent);
    -webkit-text-size-adjust: 100%;
    text-size-adjust: 100%;
    scrollbar-gutter: stable;
    scrollbar-color: color-mix(
        in oklch,
        var(--color-border) 80%,
        var(--color-text)
      )
      var(--color-background);
  }

  @media (pointer: coarse) {
    html {
      scrollbar-gutter: auto;
    }
  }

  html.enable-transitions,
  html.enable-transitions
    :is(
      a,
      article,
      aside,
      blockquote,
      body,
      button,
      code,
      div,
      footer,
      h1,
      h2,
      h3,
      h4,
      h5,
      h6,
      header,
      hr,
      li,
      main,
      nav,
      p,
      pre,
      section,
      small,
      span
    ) {
    transition:
      color 250ms ease-out,
      background-color 250ms ease-out,
      border-color 250ms ease-out,
      text-decoration-color 250ms ease-out,
      opacity 250ms ease-out,
      transform 100ms ease-out;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }

    html.enable-transitions {
      transition-duration: 0.01ms !important;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  body {
    overflow-inline: clip;
    font-size: var(--font-size-base);
    font-weight: var(--weight-normal);
    line-height: var(--leading-relaxed);
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    text-wrap: balance;
  }

  p,
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    overflow-wrap: break-word;
  }

  h1 {
    margin-block-end: 1.5rem;
    font-size: var(--font-size-2xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    text-decoration: var(--color-accent) underline 3px;
    text-underline-offset: 0.25em;
  }

  h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
  }

  h3 {
    font-size: var(--font-size-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
  }

  h4 {
    font-size: var(--font-size-md);
    font-weight: var(--weight-medium);
    line-height: var(--leading-normal);
    letter-spacing: var(--tracking-normal);
  }

  h5,
  h6 {
    font-size: var(--font-size-base);
    font-weight: var(--weight-medium);
    line-height: var(--leading-normal);
    letter-spacing: var(--tracking-normal);
  }

  small {
    font-size: var(--font-size-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-normal);
    letter-spacing: var(--tracking-normal);
  }

  img,
  picture,
  video,
  canvas,
  svg {
    display: block;
    max-inline-size: 100%;
    block-size: auto;
  }

  input,
  button,
  textarea,
  select {
    font: inherit;
  }

  a,
  button {
    -webkit-tap-highlight-color: transparent;
  }

  a svg,
  button svg {
    pointer-events: none;
  }

  button {
    background-color: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
  }

  button:active {
    transform: scale(0.96);
  }

  address {
    font-style: normal;
  }

  img {
    filter: var(--img-theme-filter);
    transition: filter 250ms ease-out;
  }

  img:hover,
  img:focus {
    filter: none;
  }

  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  main:focus-visible {
    outline: none;
  }

  ::selection {
    background-color: var(--color-selection);
    color: #fff;
  }

  .sr-only {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  @media print {
    .nav-bar,
    .skip-link,
    button {
      display: none !important;
    }

    pre.astro-code,
    pre.astro-code code {
      white-space: pre-wrap !important;
      word-break: break-all !important;
      overflow-inline: visible !important;
    }

    .content a[href^='http']::after {
      content: ' (' attr(href) ')';
      font-size: var(--font-size-sm);
      word-break: break-all;
      color: var(--color-text-muted);
    }
  }
</style>

<style>
  .page {
    display: flex;
    flex-direction: column;
    max-inline-size: 768px;
    min-block-size: 100dvb;
    margin-inline: auto;
    padding-block-start: 1rem;
    padding-block-end: 2rem;
  }

  .skip-link {
    position: absolute;
    z-index: 9999;
    inset-block-start: -100%;
    inset-inline-start: 1rem;
    padding-block: 0.5rem;
    padding-inline: 1rem;
    background: var(--color-accent);
    border-radius: 0.25rem;
    color: #fff;
    text-decoration: none;
  }

  .skip-link:focus {
    inset-block-start: 1rem;
  }

  .nav-bar {
    margin-block-end: 1.5rem;
  }

  main {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    align-items: flex-start;
    inline-size: 100%;
    margin-inline: auto;
    margin-block-end: 1.5rem;
    padding-inline-start: max(1.5rem, env(safe-area-inset-left));
    padding-inline-end: max(1.5rem, env(safe-area-inset-right));
  }
</style>
