---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  jsonLd?: Record<string, any>;
  robots?: string;
  ogType?: 'website' | 'article' | 'profile';
  ogImage?: string;
  article?: {
    publishedTime: string;
    modifiedTime?: string;
    tags: string[];
    readingTime: number;
  };
}

const {
  title,
  description,
  jsonLd,
  robots = 'max-image-preview:large, max-snippet:-1',
  ogType = 'website',
  ogImage = 'https://hawksley.dev/og-image-1200x630.png?v=2',
  article,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const isIndexable = !robots.includes('noindex');

const isHome = Astro.url.pathname === '/';
---

<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      rel="preload"
      href="/fonts/IBMPlexSans.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/fonts/IBMPlexMono.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />

    <title>{title}</title>

    <meta
      name="theme-color"
      content="#fafafa"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0f0f0f"
      media="(prefers-color-scheme: dark)"
    />

    <script is:inline>
      {
        const theme =
          (() => {
            try {
              return localStorage.getItem('theme');
            } catch {
              return null;
            }
          })() ||
          (matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light');
        document.documentElement.classList.add(theme, 'js');
        const colour = theme === 'dark' ? '#0f0f0f' : '#fafafa';
        document.head
          .querySelectorAll('meta[name="theme-color"]')
          .forEach((tag) => {
            tag.setAttribute('content', colour);
            tag.removeAttribute('media');
          });
      }
    </script>

    <meta name="description" content={description} />
    <meta name="author" content="Ethan Hawksley" />
    <meta name="robots" content={robots} />
    <meta name="format-detection" content="telephone=no" />
    <meta name="color-scheme" content="light dark" />

    {
      isIndexable && (
        <>
          <link rel="canonical" href={canonicalUrl} />

          <meta property="og:type" content={ogType} />
          <meta property="og:url" content={canonicalUrl} />
          <meta property="og:title" content={title} />
          <meta property="og:description" content={description} />
          <meta property="og:site_name" content="Ethan Hawksley" />
          <meta property="og:locale" content="en_GB" />
          <meta property="og:image" content={ogImage} />
          <meta property="og:image:alt" content={title} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta property="og:image:type" content="image/png" />

          {ogType === 'profile' && (
            <>
              <meta property="profile:first_name" content="Ethan" />
              <meta property="profile:last_name" content="Hawksley" />
            </>
          )}

          <meta name="twitter:card" content="summary_large_image" />
          <meta name="twitter:site" content="@Ethan_Hawksley" />
          <meta name="twitter:creator" content="@Ethan_Hawksley" />
          <meta name="twitter:title" content={title} />
          <meta name="twitter:description" content={description} />
          <meta name="twitter:image" content={ogImage} />
          <meta name="twitter:image:alt" content={title} />

          {article && (
            <>
              <meta name="twitter:label1" content="Author" />
              <meta name="twitter:data1" content="Ethan Hawksley" />
              <meta name="twitter:label2" content="Reading time" />
              <meta
                name="twitter:data2"
                content={`${article.readingTime} min read`}
              />

              <meta
                property="article:published_time"
                content={article.publishedTime}
              />
              {article.modifiedTime && (
                <meta
                  property="article:modified_time"
                  content={article.modifiedTime}
                />
              )}
              <meta property="article:author" content="https://hawksley.dev/" />
              {article.tags.map((tag) => (
                <meta property="article:tag" content={tag} />
              ))}
            </>
          )}

          <meta
            name="fediverse:creator"
            content="@ethanhawksley@mastodon.social"
          />
        </>
      )
    }

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Ethan Hawksley's Blog"
      href="/rss.xml"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link
      rel="icon"
      type="image/png"
      sizes="48x48"
      href="/favicon-48x48.png?v=2"
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png?v=2"
    />
    <link rel="manifest" href="/site.webmanifest?v=2" />
    <meta name="apple-mobile-web-app-title" content="Hawksley" />

    {
      isHome && (
        <>
          <link rel="me" href="https://github.com/ethan-hawksley" />
          <link rel="me" href="https://mastodon.social/@ethanhawksley" />
        </>
      )
    }

    {
      jsonLd && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(jsonLd).replaceAll('<', '\\u003c')}
        />
      )
    }

    <ClientRouter />
  </head>
  <body>
    <svg xmlns="http://www.w3.org/2000/svg" style="display:none">
      <symbol
        id="icon-external"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M7 17 17 7m0 0H7m10 0v10"></path>
      </symbol>
      <slot name="svg-symbols" />
    </svg>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div id="page">
      <div id="nav-bar">
        <Navigation />
      </div>
      <main id="main-content" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      function syncMeta(doc: Document) {
        const isDark = doc.documentElement.classList.contains('dark');
        const colour = isDark ? '#0f0f0f' : '#fafafa';
        doc.head.querySelectorAll('meta[name="theme-color"]').forEach((tag) => {
          tag.setAttribute('content', colour);
          tag.removeAttribute('media');
        });
      }

      document.addEventListener('astro:before-swap', (ev) => {
        const classList = document.documentElement.classList;
        const theme = classList.contains('dark') ? 'dark' : 'light';

        ev.newDocument.documentElement.classList.add(theme, 'js');
        ev.newDocument.documentElement.classList.remove(
          theme === 'dark' ? 'light' : 'dark',
        );

        if (classList.contains('enable-transitions')) {
          ev.newDocument.documentElement.classList.add('enable-transitions');
        }

        syncMeta(ev.newDocument);
      });

      requestAnimationFrame(() => {
        document.documentElement.classList.add('enable-transitions');
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;

    --color-background: light-dark(#fafafa, #0f0f0f);
    --color-surface: light-dark(#eaeaea, #1f1f1f);
    --color-text: light-dark(#1a1a1a, #ededed);
    --color-text-muted: light-dark(#525252, #b0b0b0);
    --color-accent: light-dark(#bf3900, #ff4f00);
    --color-border: light-dark(#e0e0e0, #2a2a2a);

    --font-size-xs: clamp(0.75rem, 0.7083rem + 0.2083vw, 0.875rem);
    --font-size-sm: clamp(0.875rem, 0.8333rem + 0.2083vw, 1rem);
    --font-size-base: clamp(1rem, 0.9583rem + 0.2083vw, 1.125rem);
    --font-size-md: clamp(1.1875rem, 1.1042rem + 0.4167vw, 1.4375rem);
    --font-size-lg: clamp(1.375rem, 1.25rem + 0.625vw, 1.75rem);
    --font-size-xl: clamp(1.625rem, 1.4167rem + 1.0417vw, 2.25rem);
    --font-size-2xl: clamp(2rem, 1.6667rem + 1.6667vw, 3rem);

    --leading-tight: 1.1;
    --leading-snug: 1.25;
    --leading-normal: 1.5;
    --leading-relaxed: 1.65;

    --tracking-tight: -0.025em;
    --tracking-snug: -0.015em;
    --tracking-normal: -0.01em;

    --weight-normal: 400;
    --weight-medium: 500;
    --weight-semibold: 600;

    --font-sans: 'IBM Plex Sans', system-ui, sans-serif;
    --font-mono: 'IBM Plex Mono', ui-monospace, 'Cascadia Code', monospace;
  }

  :root.dark {
    color-scheme: dark;
  }

  @media (prefers-color-scheme: dark) {
    :root:not(.light) {
      color-scheme: dark;
    }
  }

  @font-face {
    font-family: 'IBM Plex Sans';
    font-style: normal;
    font-weight: 100 700;
    font-display: swap;
    src: url('/fonts/IBMPlexSans.woff2') format('woff2');
  }

  @font-face {
    font-family: 'IBM Plex Mono';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('/fonts/IBMPlexMono.woff2') format('woff2');
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  * {
    margin: 0;
  }

  ul[role='list'],
  ol[role='list'] {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  html {
    background-color: var(--color-background);
    color: var(--color-text);
    font-family: var(--font-sans);
    accent-color: var(--color-accent);
    scroll-behavior: smooth;
    scrollbar-gutter: stable;
    scrollbar-color: color-mix(
        in srgb,
        var(--color-border) 80%,
        var(--color-text)
      )
      var(--color-background);
  }

  html.enable-transitions {
    transition:
      background-color 250ms ease-out,
      color 250ms ease-out,
      border-color 250ms ease-out,
      text-decoration-color 250ms ease-out;

    body,
    header,
    nav,
    div,
    blockquote,
    h1,
    h2,
    h3,
    h4,
    h5,
    h6,
    p,
    pre,
    ul,
    ol,
    li,
    span,
    small,
    a,
    button,
    .astro-code,
    .copy-button {
      transition:
        background-color 250ms ease-out,
        color 250ms ease-out,
        border-color 250ms ease-out,
        text-decoration-color 250ms ease-out;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }

    html {
      scroll-behavior: auto;
    }

    html.enable-transitions {
      transition-duration: 0.01ms !important;
    }
  }

  body {
    font-size: var(--font-size-base);
    line-height: var(--leading-relaxed);
    font-weight: var(--weight-normal);
    text-size-adjust: 100%;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    text-wrap: balance;
    text-rendering: optimizeLegibility;
  }

  p,
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    overflow-wrap: break-word;
  }

  h1 {
    font-size: var(--font-size-2xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    font-weight: var(--weight-semibold);
    margin-bottom: 1.5rem;
    text-decoration: var(--color-accent) underline 3px;
    text-underline-offset: 0.25em;
  }

  h2 {
    font-size: var(--font-size-xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
    font-weight: var(--weight-semibold);
  }

  h3 {
    font-size: var(--font-size-lg);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
    font-weight: var(--weight-semibold);
  }

  h4 {
    font-size: var(--font-size-md);
    line-height: var(--leading-normal);
    letter-spacing: var(--tracking-normal);
    font-weight: var(--weight-medium);
  }

  h5,
  h6 {
    font-size: var(--font-size-base);
    line-height: var(--leading-normal);
    letter-spacing: var(--tracking-normal);
    font-weight: var(--weight-medium);
  }

  p {
    text-wrap: pretty;
  }

  p,
  li {
    hanging-punctuation: first allow-end last;
  }

  small {
    font-size: var(--font-size-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-normal);
    line-height: var(--leading-normal);
  }

  img,
  picture,
  video,
  canvas,
  svg {
    display: block;
    max-width: 100%;
    height: auto;
  }

  input,
  button,
  textarea,
  select {
    font: inherit;
  }

  a,
  button {
    -webkit-tap-highlight-color: transparent;
  }

  a svg,
  button svg {
    pointer-events: none;
  }

  button {
    background-color: transparent;
    background-image: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    transition: transform 100ms ease-out;
  }

  button:active {
    transform: scale(0.96);
  }

  address {
    font-style: normal;
  }

  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 0.125rem;
  }

  ::selection {
    background-color: var(--color-accent);
    color: #fff;
  }

  .dark ::selection {
    background-color: #b33800;
  }

  @media (prefers-color-scheme: dark) {
    :root:not(.light) ::selection {
      background-color: #b33800;
    }
  }

  ::-webkit-scrollbar {
    width: 10px;
  }

  ::-webkit-scrollbar-track {
    background: var(--color-background);
  }

  ::-webkit-scrollbar-thumb {
    background-color: color-mix(
      in srgb,
      var(--color-border) 80%,
      var(--color-text)
    );
    border-radius: 10px;
    border: 2px solid var(--color-background);
  }

  ::-webkit-scrollbar-thumb:hover {
    background-color: var(--color-text-muted);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }
</style>

<style>
  #page {
    max-width: 768px;
    margin-inline: auto;
    padding-top: 1rem;
    padding-bottom: 2rem;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 0.25rem;
    z-index: 9999;
    text-decoration: none;
  }

  .skip-link:focus {
    top: 1rem;
  }

  #nav-bar {
    margin-bottom: 1.5rem;
  }

  main {
    margin-inline: auto;
    padding-inline: 1.5rem;
    margin-bottom: 1.5rem;
    width: 100%;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
</style>
